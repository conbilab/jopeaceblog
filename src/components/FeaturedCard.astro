---
import type { Record_ } from '../lib/utils';
import { formatDate } from '../lib/utils';
import { getType } from '../lib/taxonomy';
const { record } = Astro.props as { record: Record_ };
const { data } = record;
const href = `/records/${record.id}`;
const type = getType(data.type);
---

<article class="feat reveal">
  <a href={href} class="feat-link">
    {data.cover && (
      <div class="feat-media"><img src={data.cover} alt={data.title} loading="eager" /></div>
    )}
    <div class="feat-body">
      <span class="feat-kicker">대표 기록</span>
      <h3 class="feat-title">{data.title}</h3>
      {data.description && <p class="feat-desc">{data.description}</p>}
      <div class="feat-foot">
        <span class="feat-tags">
          <span class="ft-type">{type.label}</span>
          <span class="ft-date">{formatDate(data.date)}</span>
        </span>
        <span class="feat-read">읽기 →</span>
      </div>
    </div>
    <span class="feat-quote" aria-hidden="true">”</span>
  </a>
</article>

<style>
  .feat { position: relative; background: var(--ink-strong); border-radius: var(--r-hero); overflow: hidden; box-shadow: var(--shadow-md); transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease); }
  :root[data-theme='dark'] .feat { background: #100e0a; border: 1px solid var(--line); }
  .feat:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
  .feat-link { display: grid; grid-template-columns: 1fr 1fr; min-height: 19rem; position: relative; }
  .feat:has(.feat-media) .feat-link { grid-template-columns: 1.05fr 1fr; }
  .feat:not(:has(.feat-media)) .feat-link { grid-template-columns: 1fr; }

  .feat-media { overflow: hidden; }
  .feat-media img { width: 100%; height: 100%; object-fit: cover; }

  .feat-body { display: flex; flex-direction: column; justify-content: center; gap: 0.9rem; padding: clamp(1.8rem, 3.2vw, 3rem); color: #f3ede0; position: relative; z-index: 1; }
  .feat-kicker { font-size: 0.72rem; font-weight: 800; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-warm); }
  :root[data-theme='dark'] .feat-kicker { color: #d2a96f; }
  .feat-title { font-size: clamp(1.55rem, 2.7vw, 2.25rem); font-weight: 800; line-height: 1.28; letter-spacing: -0.035em; color: #fbf7ec; text-wrap: balance; }
  .feat-desc { color: #cbc4b2; font-size: 1.02rem; line-height: 1.7; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .feat-foot { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: 0.4rem; }
  .feat-tags { display: flex; align-items: center; gap: 0.7rem; font-size: 0.82rem; color: #aaa291; }
  .ft-type { color: var(--color-warm); font-weight: 700; }
  .ft-date { font-variant-numeric: tabular-nums; }
  .feat-read { font-size: 0.9rem; font-weight: 800; color: #fbf7ec; }
  .feat:hover .feat-read { color: var(--color-warm); }

  /* 큰 따옴표 장식(이모지 대신, 절제) */
  .feat-quote { position: absolute; right: clamp(1rem, 3vw, 2.5rem); top: -1.5rem; font-family: var(--font-serif); font-size: 14rem; line-height: 1; color: rgba(255,255,255,0.05); pointer-events: none; z-index: 0; }
  .feat:has(.feat-media) .feat-quote { display: none; }

  @media (max-width: 820px) {
    .feat-link, .feat:has(.feat-media) .feat-link { grid-template-columns: 1fr; }
    .feat-media { aspect-ratio: 16 / 8; }
  }
</style>
