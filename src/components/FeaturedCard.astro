---
import type { Record_ } from '../lib/utils';
import { formatDate } from '../lib/utils';
import { getType } from '../lib/taxonomy';
import Badge from './Badge.astro';

interface Props { record: Record_; }
const { record } = Astro.props;
const { data } = record;
const href = `/records/${record.id}`;
const type = getType(data.type);
const style = `--tbg: var(${type.bg}); --tink: var(${type.ink});`;
---

<article class="feat reveal" style={style}>
  <a href={href} class="feat-link">
    <div class="feat-visual">
      {data.cover ? (
        <img src={data.cover} alt={data.title} loading="eager" />
      ) : (
        <div class="feat-block">
          <span class="fb-emoji" aria-hidden="true">{type.emoji}</span>
          <span class="fb-deco" aria-hidden="true"></span>
        </div>
      )}
    </div>
    <div class="feat-body">
      <span class="feat-kicker">대표 기록</span>
      <div class="feat-badges">
        <Badge kind="type" value={data.type} />
        <Badge kind="topic" value={data.topic} />
        {data.status !== 'completed' && <Badge kind="status" value={data.status} />}
      </div>
      <h3 class="feat-title">{data.title}</h3>
      {data.description && <p class="feat-desc">{data.description}</p>}
      <div class="feat-foot">
        <time class="feat-date">{formatDate(data.date)}</time>
        <span class="feat-read">읽기 →</span>
      </div>
    </div>
  </a>
</article>

<style>
  .feat { background: var(--color-card); border: 1px solid var(--line); border-radius: var(--r-hero); overflow: hidden; box-shadow: var(--shadow-md); transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease); }
  .feat:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .feat-link { display: grid; grid-template-columns: 1.05fr 1fr; min-height: 21rem; }

  .feat-visual { position: relative; overflow: hidden; }
  .feat-visual img { width: 100%; height: 100%; object-fit: cover; }
  .feat-block { width: 100%; height: 100%; position: relative; background: radial-gradient(120% 100% at 80% 10%, color-mix(in srgb, var(--tbg) 85%, #fff), var(--tbg)); }
  .fb-emoji { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); font-size: 7rem; line-height: 1; filter: saturate(1.1); transition: transform var(--dur-slow) var(--ease); }
  .feat:hover .fb-emoji { transform: translate(-50%, -54%) rotate(-5deg) scale(1.05); }
  .fb-deco { position: absolute; inset: 1.2rem; border: 1.5px dashed color-mix(in srgb, var(--tink) 35%, transparent); border-radius: calc(var(--r-hero) - 8px); pointer-events: none; }

  .feat-body { display: flex; flex-direction: column; justify-content: center; gap: 0.7rem; padding: clamp(1.6rem, 3vw, 2.6rem); }
  .feat-kicker { font-size: 0.74rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-primary); }
  .feat-badges { display: flex; flex-wrap: wrap; gap: 0.45rem; align-items: center; }
  .feat-title { font-size: clamp(1.5rem, 2.6vw, 2.15rem); font-weight: 800; line-height: 1.25; letter-spacing: -0.035em; color: var(--ink-strong); text-wrap: balance; transition: color var(--dur-fast); }
  .feat:hover .feat-title { color: var(--color-primary); }
  .feat-desc { color: var(--ink-soft); font-size: 1.02rem; line-height: 1.7; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .feat-foot { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: 0.5rem; }
  .feat-date { font-size: 0.85rem; color: var(--ink-mute); font-variant-numeric: tabular-nums; }
  .feat-read { font-size: 0.9rem; font-weight: 800; color: var(--color-primary); }

  @media (max-width: 820px) {
    .feat-link { grid-template-columns: 1fr; }
    .feat-visual { aspect-ratio: 16 / 8; min-height: 0; }
    .fb-emoji { font-size: 5rem; }
  }
</style>
