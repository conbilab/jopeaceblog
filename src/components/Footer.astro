---
import { SITE, SOCIAL, NAV } from '../lib/site';
const year = 2026;
const more = [
  { label: '소개', href: '/about' },
  { label: '지금 하는 일', href: '/now' },
  { label: '문의', href: '/contact' },
  { label: 'RSS 구독', href: '/rss.xml' },
];
---

<footer class="footer">
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-brand">
        <div class="fb-name">{SITE.title} <span class="fb-en">Peace Note</span></div>
        <p class="fb-sub">{SITE.subtitle}</p>
        <p class="fb-slogan">“{SITE.slogan}”</p>
      </div>

      <nav class="foot-col" aria-label="둘러보기">
        <h3>기록</h3>
        <ul role="list">
          {NAV.filter((n) => n.href !== '/contact').map((n) => (<li><a href={n.href}>{n.label}</a></li>))}
        </ul>
      </nav>

      <nav class="foot-col" aria-label="더 보기">
        <h3>더 보기</h3>
        <ul role="list">
          {more.map((m) => (<li><a href={m.href}>{m.label}</a></li>))}
          {SOCIAL.filter((s) => s.href && s.href !== '#').map((s) => {
            const ext = s.href.startsWith('http');
            return (<li><a href={s.href} target={ext ? '_blank' : undefined} rel={ext ? 'noopener noreferrer' : undefined}>{s.label}</a></li>);
          })}
        </ul>
      </nav>
    </div>

    <div class="foot-bottom">
      <p>© {year} {SITE.author}({SITE.authorHandle}) · 피스노트는 한 사람이 부끄럽지 않게 살기 위해 남기는 공개 기록장입니다.</p>
    </div>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--line); background: var(--bg-soft); padding-block: var(--space-xl) var(--space-lg); margin-top: var(--space-3xl); }
  .foot-top { display: grid; grid-template-columns: 1.7fr 1fr 1fr; gap: 2.5rem; padding-bottom: var(--space-lg); border-bottom: 1px solid var(--line); }
  .fb-name { font-weight: 800; font-size: 1.3rem; letter-spacing: -0.04em; color: var(--ink-strong); }
  .fb-en { font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-primary); font-weight: 600; margin-left: 0.3rem; }
  .fb-sub { margin-top: 0.9rem; color: var(--ink-soft); font-size: 0.95rem; max-width: 38ch; line-height: 1.7; }
  .fb-slogan { margin-top: 0.8rem; font-family: var(--font-serif); font-style: italic; font-size: 1.05rem; color: var(--color-primary-ink); }

  .foot-col h3 { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-mute); font-weight: 800; margin-bottom: 1rem; }
  .foot-col ul { display: flex; flex-direction: column; gap: 0.65rem; }
  .foot-col a { font-size: 0.92rem; color: var(--ink-soft); font-weight: 600; transition: color var(--dur-fast); }
  .foot-col a:hover { color: var(--color-primary); }

  .foot-bottom { padding-top: var(--space-md); }
  .foot-bottom p { font-size: 0.82rem; color: var(--ink-mute); line-height: 1.6; }

  @media (max-width: 760px) { .foot-top { grid-template-columns: 1fr 1fr; } .foot-brand { grid-column: 1 / -1; } }
  @media (max-width: 480px) { .foot-top { grid-template-columns: 1fr; } }
</style>
