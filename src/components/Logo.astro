---
/**
 * 조피스 / 피스웍스 — 평화의 비둘기(peace dove) 라인 마크.
 * currentColor 기반이라 어떤 배경/팔레트에서도 색이 자연스럽게 따라옵니다.
 */
interface Props {
  size?: number;
  stroke?: number;
  class?: string;
  title?: string;
}
const { size = 36, stroke = 2, class: className = '', title = '조피스' } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  role="img"
  aria-label={title}
  class={`jopis-logo ${className}`}
  xmlns="http://www.w3.org/2000/svg"
>
  <circle cx="32" cy="32" r="29" stroke="currentColor" stroke-width={stroke} opacity="0.9" />
  <!-- 비둘기 몸통 + 머리 (오른쪽을 향해 날아오르는 형태) -->
  <path
    d="M16 40c6.5 1.2 12.6-1 17.4-6.2 1.6 2.6 4.2 4.2 7.6 4.2 0.2 1.9 1.3 3.3 3.4 3.9-2 1.6-4.4 2.2-7 1.9"
    stroke="currentColor"
    stroke-width={stroke}
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <!-- 날개 (위로 펼친 곡선) -->
  <path
    d="M19 38c1.2-7.2 6-12.8 13.4-15.2-3 3.4-4.2 7-3.6 11"
    stroke="currentColor"
    stroke-width={stroke}
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <!-- 부리 -->
  <path d="M44.4 36.1l3.4-1.1" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" />
</svg>

<style>
  .jopis-logo {
    display: block;
    overflow: visible;
  }
</style>
