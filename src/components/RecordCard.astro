---
import type { Record_ } from '../lib/utils';
import { formatDot } from '../lib/utils';
import { getType } from '../lib/taxonomy';
import Badge from './Badge.astro';

interface Props { record: Record_; index?: number; compact?: boolean; }
const { record, index = 0, compact = false } = Astro.props;
const { data } = record;
const href = `/records/${record.id}`;
const type = getType(data.type);
const dotVar = type.bg.replace('-bg', '-dot');
const showStatus = data.status !== 'completed';
const style = `--accent: var(${dotVar});`;
---

<article class:list={['rec', 'reveal', { 'rec--compact': compact }]} data-delay={String((index % 4) + 1)} style={style}>
  <a href={href} class="rec-link">
    {data.cover && (
      <div class="rec-media"><img src={data.cover} alt={data.title} loading="lazy" decoding="async" /></div>
    )}
    <div class="rec-body">
      <div class="rec-badges">
        <Badge kind="type" value={data.type} />
        <Badge kind="topic" value={data.topic} />
        {showStatus && <Badge kind="status" value={data.status} />}
      </div>
      <h3 class="rec-title">{data.title}</h3>
      {data.description && <p class="rec-desc">{data.description}</p>}
      <div class="rec-meta">
        <time class="rec-date" datetime={data.date.toISOString()}>{formatDot(data.date)}</time>
        {data.tags.length > 0 && (<span class="rec-tags">{data.tags.slice(0, 2).map((t) => `#${t}`).join(' ')}</span>)}
      </div>
    </div>
  </a>
</article>

<style>
  .rec { position: relative; background: var(--color-card); border: 1px solid var(--line); border-radius: var(--r-card); overflow: hidden; transition: border-color var(--dur) var(--ease), transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease); }
  /* 상단 얇은 유형색 룰(절제된 색) */
  .rec::before { content: ''; position: absolute; left: 0; right: 0; top: 0; height: 3px; background: var(--accent); opacity: 0.85; }
  .rec:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--line-strong); }
  .rec-link { display: flex; flex-direction: column; height: 100%; }

  .rec-media { aspect-ratio: 16 / 9; overflow: hidden; border-bottom: 1px solid var(--line); }
  .rec-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s var(--ease); }
  .rec:hover .rec-media img { transform: scale(1.03); }

  .rec-body { display: flex; flex-direction: column; gap: 0.5rem; padding: 1.3rem 1.35rem 1.3rem; flex: 1; }
  .rec-badges { display: flex; flex-wrap: wrap; gap: 0.55rem 0.7rem; align-items: center; }
  .rec-title { font-size: 1.12rem; font-weight: 800; line-height: 1.42; letter-spacing: -0.025em; color: var(--ink-strong); text-wrap: balance; transition: color var(--dur-fast); }
  .rec:hover .rec-title { color: var(--color-primary-deep); }
  .rec-desc { color: var(--ink-soft); font-size: 0.93rem; line-height: 1.65; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .rec-meta { margin-top: auto; padding-top: 0.6rem; display: flex; flex-wrap: wrap; gap: 0.7rem; align-items: baseline; font-size: 0.8rem; color: var(--ink-mute); border-top: 1px solid var(--line-soft); }
  .rec-date { font-variant-numeric: tabular-nums; }
  .rec-tags { color: var(--ink-mute); font-weight: 600; }

  .rec--compact .rec-body { padding: 1.1rem 1.2rem; gap: 0.45rem; }
  .rec--compact .rec-title { font-size: 1.02rem; -webkit-line-clamp: 2; }
  .rec--compact .rec-desc { -webkit-line-clamp: 2; font-size: 0.88rem; }
</style>
