---
import type { Post } from '../lib/utils';
import { formatDate } from '../lib/utils';
import { getCategory, GROWTH } from '../lib/categories';

interface Props {
  post: Post;
  variant?: 'default' | 'feature' | 'compact' | 'list';
  index?: number;
}
const { post, variant = 'default', index = 0 } = Astro.props;
const { data } = post;
const cat = getCategory(data.category);
const href = `/posts/${post.id}`;
const growth = GROWTH[data.growth];
const showGrowth = data.growth !== 'evergreen';
const style = `--cat: var(${cat.colorVar}); --cat-bg: var(${cat.bgVar});`;
const delay = String((index % 4) + 1);
---

{variant === 'list' ? (
  <a href={href} class="pc-list reveal" data-delay={delay} style={style}>
    <span class="pc-list-date num">{formatDate(data.pubDate)}</span>
    <span class="pc-list-main">
      <span class="cat-label" style="--cat: var(--cat)">{cat.name}</span>
      <span class="pc-list-title">{data.title}</span>
    </span>
    <span class="pc-list-arrow" aria-hidden="true">→</span>
  </a>
) : (
  <article class:list={['pc', 'card', `pc--${variant}`, 'reveal']} data-delay={delay} style={style}>
    <a href={href} class="pc-link">
      {data.cover && (
        <div class="pc-media">
          <img src={data.cover} alt={data.coverAlt ?? ''} loading="lazy" decoding="async" />
          <span class="pc-cat-chip">{cat.emoji} {cat.name}</span>
        </div>
      )}
      <div class="pc-body">
        {!data.cover && <span class="cat-label pc-cat-text">{cat.name}</span>}
        <h3 class="pc-title">{data.title}</h3>
        {data.summary && <p class="pc-summary">{data.summary}</p>}
        <div class="pc-meta">
          <time class="num" datetime={data.pubDate.toISOString()}>{formatDate(data.pubDate)}</time>
          {showGrowth && <span class="pc-growth">· {growth.emoji} {growth.label}</span>}
          {data.tags.length > 0 && <span class="pc-tags">· {data.tags.slice(0, 2).map((t) => `#${t}`).join(' ')}</span>}
        </div>
      </div>
    </a>
  </article>
)}

<style>
  .pc { overflow: hidden; }
  .pc-link { display: flex; flex-direction: column; height: 100%; }
  .pc-media { position: relative; aspect-ratio: 16 / 10; overflow: hidden; background: var(--bg-soft); }
  .pc-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s var(--ease); filter: saturate(0.96); }
  .pc:hover .pc-media img { transform: scale(1.045); }
  .pc-cat-chip {
    position: absolute; left: 0.75rem; top: 0.75rem; font-size: 0.72rem; font-weight: 700;
    background: color-mix(in srgb, var(--bg) 88%, transparent); color: var(--cat);
    padding: 0.35em 0.7em; border-radius: var(--r-pill); backdrop-filter: blur(6px);
    border: 1px solid color-mix(in srgb, var(--cat) 30%, transparent);
  }
  .pc-body { padding: 1.2rem 1.25rem 1.3rem; display: flex; flex-direction: column; gap: 0.55rem; flex: 1; }
  .pc-cat-text { --cat: var(--cat); }
  .pc-title {
    font-size: var(--step-1); font-weight: 800; line-height: 1.32; letter-spacing: -0.03em;
    color: var(--ink-strong); transition: color var(--dur-fast);
  }
  .pc:hover .pc-title { color: var(--brand); }
  .pc-summary { color: var(--ink-soft); font-size: 0.94rem; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .pc-meta { margin-top: auto; padding-top: 0.4rem; font-size: 0.82rem; color: var(--ink-mute); display: flex; flex-wrap: wrap; gap: 0.35em; align-items: baseline; }
  .pc-tags { color: var(--gold-ink); font-weight: 600; }

  /* feature(대형) */
  .pc--feature .pc-media { aspect-ratio: 16 / 9; }
  .pc--feature .pc-title { font-size: var(--step-2); }
  .pc--feature .pc-summary { -webkit-line-clamp: 3; }

  /* compact (커버 작게) */
  .pc--compact .pc-media { aspect-ratio: 3 / 2; }
  .pc--compact .pc-title { font-size: var(--step-0); }

  /* list 행 */
  .pc-list {
    display: grid; grid-template-columns: auto 1fr auto; align-items: baseline; gap: 1.2rem;
    padding: 1.15rem 0.4rem; border-bottom: 1px dashed var(--dashed); transition: transform var(--dur) var(--ease), background var(--dur) var(--ease); border-radius: var(--r-sm);
  }
  .pc-list:hover { transform: translateX(6px); background: linear-gradient(90deg, var(--cat-bg), transparent 70%); }
  .pc-list-date { font-size: 0.82rem; color: var(--ink-mute); white-space: nowrap; min-width: 6.5rem; }
  .pc-list-main { display: flex; flex-direction: column; gap: 0.3rem; }
  .pc-list-title { font-size: var(--step-0); font-weight: 700; color: var(--ink-strong); letter-spacing: -0.02em; transition: color var(--dur-fast); }
  .pc-list:hover .pc-list-title { color: var(--brand); }
  .pc-list-arrow { color: var(--cat); opacity: 0; transform: translateX(-6px); transition: all var(--dur) var(--ease); }
  .pc-list:hover .pc-list-arrow { opacity: 1; transform: none; }

  @media (max-width: 560px) {
    .pc-list { grid-template-columns: 1fr auto; }
    .pc-list-date { order: 2; grid-column: 1; min-width: 0; }
    .pc-list-main { grid-column: 1 / -1; order: 1; }
  }
</style>
