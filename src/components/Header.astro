---
import Logo from './Logo.astro';
import { NAV, SITE } from '../lib/site';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
function isActive(href: string) {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
}
---

<header class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="brand" aria-label={`${SITE.title} 홈`}>
      <span class="brand-mark"><Logo size={34} stroke={2.2} /></span>
      <span class="brand-text">
        <span class="brand-title">{SITE.title}</span>
        <span class="brand-sub">JOPIS · 조재빈의 기록</span>
      </span>
    </a>

    <nav class="nav-links" aria-label="주요 메뉴">
      {NAV.map((item) => (
        <a href={item.href} class:list={['nav-link', 'u-line', { active: isActive(item.href) }]} aria-current={isActive(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="nav-actions">
      <a href="/search" class="icon-btn" aria-label="검색">
        <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7" /><path d="m20 20-3.5-3.5" /></svg>
      </a>
      <button class="icon-btn" data-theme-toggle aria-label="라이트/다크 모드 전환" aria-pressed="false" type="button">
        <svg class="i-sun" viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4.5" /><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" /></svg>
        <svg class="i-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" /></svg>
      </button>
      <button class="icon-btn nav-burger" data-nav-toggle aria-label="메뉴 열기" aria-expanded="false" aria-controls="mobile-nav" type="button">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-label="모바일 메뉴" inert>
    <div class="wrap">
      {NAV.map((item) => (
        <a href={item.href} class:list={['m-link', { active: isActive(item.href) }]}>{item.label}</a>
      ))}
      <a href="/search" class="m-link">검색</a>
    </div>
  </nav>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: var(--z-nav);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(1.4) blur(14px);
    -webkit-backdrop-filter: saturate(1.4) blur(14px);
    border-bottom: 1px solid var(--line);
  }
  /* blur 미지원/비활성 환경에서는 불투명 배경으로 폴백 (가독성 보장) */
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .nav { background: var(--bg); }
  }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; height: 4.4rem; }
  .brand { display: flex; align-items: center; gap: 0.7rem; }
  .brand-mark { color: var(--brand); display: grid; place-items: center; transition: transform var(--dur) var(--ease); }
  .brand:hover .brand-mark { transform: rotate(-8deg) scale(1.05); }
  .brand-text { display: flex; flex-direction: column; line-height: 1.05; }
  .brand-title { font-weight: 800; font-size: 1.06rem; letter-spacing: -0.03em; color: var(--ink-strong); }
  .brand-sub { font-family: var(--font-serif); font-style: italic; font-size: 0.66rem; letter-spacing: 0.04em; color: var(--ink-mute); margin-top: 1px; }

  .nav-links { display: flex; gap: 1.6rem; align-items: center; }
  .nav-link { font-size: 0.95rem; font-weight: 600; color: var(--ink-soft); transition: color var(--dur-fast); }
  .nav-link:hover, .nav-link.active { color: var(--brand); }
  .nav-link.active { color: var(--ink-strong); }

  .nav-actions { display: flex; align-items: center; gap: 0.4rem; }
  .icon-btn {
    display: grid; place-items: center; width: 2.4rem; height: 2.4rem; border-radius: var(--r-pill);
    color: var(--ink-soft); transition: background var(--dur-fast), color var(--dur-fast);
  }
  .icon-btn:hover { background: var(--bg-soft); color: var(--brand); }
  .i-moon { display: none; }
  :root[data-theme='dark'] .i-sun { display: none; }
  :root[data-theme='dark'] .i-moon { display: block; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .i-sun { display: none; }
    :root:not([data-theme]) .i-moon { display: block; }
  }

  .nav-burger { display: none; flex-direction: column; gap: 4px; }
  .nav-burger span { width: 18px; height: 2px; background: currentColor; border-radius: 2px; transition: transform var(--dur) var(--ease), opacity var(--dur); }
  body.nav-open .nav-burger span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  body.nav-open .nav-burger span:nth-child(2) { opacity: 0; }
  body.nav-open .nav-burger span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  .mobile-nav {
    display: none; overflow: hidden; max-height: 0;
    border-bottom: 1px solid transparent; transition: max-height var(--dur) var(--ease), border-color var(--dur);
    background: var(--bg);
  }
  .mobile-nav[data-open] { max-height: 70vh; border-color: var(--line); }
  .mobile-nav .wrap { display: flex; flex-direction: column; padding-block: 0.6rem 1.2rem; }
  .m-link { padding: 0.85rem 0.2rem; font-size: 1.05rem; font-weight: 700; color: var(--ink-strong); border-bottom: 1px dashed var(--dashed); }
  .m-link.active { color: var(--brand); }

  @media (max-width: 800px) {
    .nav-links { display: none; }
    .nav-burger { display: flex; }
    .mobile-nav { display: block; }
    .brand-sub { display: none; }
  }
</style>
