---
import BaseLayout from '../layouts/BaseLayout.astro';
import Logo from '../components/Logo.astro';
import { STATS, SITE } from '../lib/site';

const story = [
  {
    n: 'Why',
    t: '왜 하는가',
    h: '저는 콘텐츠로 사람들 사이에 평화를 만들고 싶습니다.',
    b: '제가 본 소상공인 사장님들은 대부분 불안했습니다. 광고비를 썼는데 문의가 없어서, 어디에 돈을 더 넣어야 할지 몰라서. 마케팅이 누군가에겐 성장의 도구겠지만, 현장에서 제가 본 건 자주 ‘불안을 파는 시장’이었어요. 그래서 결심했습니다. 헛돈 쓰지 않게, 다음 달을 덜 무섭게. 저에게 평화는 그렇게 구체적인 단어입니다.',
  },
  {
    n: 'How',
    t: '어떻게 하는가',
    h: '화려함 대신, 문의되는 구조와 정직함으로.',
    b: '예쁜 콘텐츠는 감탄을 만들지만 결제를 만들지는 못합니다. 고객은 발견하고, 검색하고, 비교한 뒤에야 문의합니다. 저는 그 길이 끊기지 않도록 구조를 설계합니다. 그리고 맞지 않으면 솔직히 말씀드립니다. 무리하게 권하지 않습니다.',
  },
  {
    n: 'What',
    t: '무엇을 하는가',
    h: 'AI 영상 · AI 마케팅 강의 · 1:1 퍼널 설계.',
    b: '영상 12년, 마케팅 6년, 강의 6년. 기획부터 제작, 상담, 납품까지 한 사람이 모두 경험했기에 콘텐츠부터 매출까지 끊김 없이 연결합니다. 그 일을 ‘피스웍스’라는 이름으로 합니다.',
  },
];
---

<BaseLayout title="소개" description={SITE.description}>
  <!-- 인트로 -->
  <section class="about-hero">
    <div class="wrap about-hero-inner">
      <div class="ah-copy">
        <span class="kicker">조피스라는 사람</span>
        <h1 class="h1 display ah-title">콘텐츠로 평화를 만드는 사람,<br/><em>조재빈</em>입니다.</h1>
        <p class="lead ah-lead">
          대전에서 1인 기업 피스웍스를 운영합니다. 별명은 조피스, 또는 ‘배워서 남 주는 조피디’.
          잘된 것도 망한 것도 다 적는 이 블로그가, 굳이 설명하지 않아도 제가 어떤 사람인지 말해주길 바랍니다.
        </p>
        <div class="ah-cta">
          <a href="/now" class="btn btn-primary">요즘의 저는 (Now) →</a>
          <a href="/contact" class="btn btn-ghost">연락하기</a>
        </div>
      </div>
      <figure class="ah-figure">
        <img src="/images/press-photo.jpg" alt="조재빈(조피스)" loading="eager" />
        <figcaption>“비싼 광고 없이도, 제대로 설명하면 충분히 승부할 수 있습니다.”</figcaption>
      </figure>
    </div>
  </section>

  <!-- 실적 스트립 -->
  <section class="about-stats">
    <div class="wrap">
      <ul role="list">
        {STATS.map((s) => (
          <li><span class="num as-v">{s.value}</span><span class="as-l">{s.label}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 골든서클 스토리 -->
  <section class="section about-story">
    <div class="wrap">
      <div class="sec-head center" style="margin-inline:auto">
        <span class="kicker kicker--caps" style="justify-content:center">My golden circle</span>
        <h2 class="h2 display">서비스를 말하기 전에, 이유부터</h2>
      </div>
      <div class="story-list">
        {story.map((s, i) => (
          <article class="story-row reveal" data-delay={String(i + 1)}>
            <div class="sr-mark"><span class="sr-n num">{s.n}</span><span class="sr-t">{s.t}</span></div>
            <div class="sr-body">
              <h3 class="sr-h">{s.h}</h3>
              <p class="sr-b">{s.b}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 전환점 / 대표 실적 -->
  <section class="section about-proof">
    <div class="wrap about-proof-inner">
      <div class="ap-copy reveal">
        <span class="kicker">The turning point</span>
        <h2 class="h2 display">세차기 한 대도 못 팔던 제가,<br/>전국 90개 가맹점을 만들었습니다.</h2>
        <p class="lead">
          충동구매가 불가능한 수천만 원짜리 기계. 처음엔 저도 화려한 광고에 힘을 줬지만 전화는 울리지 않았어요.
          광고를 멈추고 한 달을 검색만 했습니다. 예비 창업자가 무엇이 무서워 결제 앞에서 멈추는지를요.
          답은 단순했습니다 — <strong>화려함이 아니라, 미리 답을 만들어 두는 ‘구조’.</strong> 그게 90개를 만들었습니다.
        </p>
        <a href="/posts/carwash-90-stores" class="btn-text">그 과정 전부 읽기</a>
      </div>
      <div class="ap-media reveal" data-delay="1">
        <img src="/images/lecture-5.jpg" alt="강의 현장" loading="lazy" />
        <img src="/images/video-2.jpg" alt="영상 제작" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- 가치 -->
  <section class="section about-values">
    <div class="wrap">
      <div class="av-card">
        <span class="av-mark"><Logo size={48} stroke={2} /></span>
        <h2 class="h2 display">피스웍스라는 이름에 담은 것</h2>
        <p class="av-lead">
          많은 분들이 제가 만든 콘텐츠와 강의, 컨설팅으로 돈을 벌고, 그 힘으로 다시 선한 영향력을 나눠
          이 세상의 0.001%라도 더 평화로워지기를 바랍니다.
        </p>
        <p class="av-give">🕊️ 그래서 매년 <strong>수익의 1%</strong>를 모아 아이들을 위한 재능·수익 기부를 합니다. 작지만 꾸준히.</p>
      </div>
    </div>
  </section>

  <!-- 사업자 정보 -->
  <section class="about-biz">
    <div class="wrap">
      <dl class="biz-grid">
        <div><dt>상호</dt><dd>피스웍스(Peaceworks)</dd></div>
        <div><dt>대표</dt><dd>조재빈</dd></div>
        <div><dt>사업자등록번호</dt><dd class="num">731-24-00997</dd></div>
        <div><dt>업종</dt><dd>광고대행 · 영상콘텐츠 제작 · 미디어콘텐츠 창작</dd></div>
        <div><dt>거점</dt><dd>대전</dd></div>
        <div><dt>이메일</dt><dd><a href={`mailto:${SITE.email}`}>{SITE.email}</a></dd></div>
      </dl>
      <div class="biz-cta">
        <a href="/timeline" class="btn btn-ghost">걸어온 길 보기 →</a>
        <a href="/contact" class="btn btn-primary">함께 일하고 싶다면</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero { padding-top: clamp(2rem, 4vw, 3.5rem); padding-bottom: 2rem; }
  .about-hero-inner { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  .ah-title { margin-top: 1rem; }
  .ah-title em { font-style: italic; color: var(--brand); }
  .ah-lead { margin-top: 1.4rem; max-width: 40ch; }
  .ah-cta { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 1.8rem; }
  .ah-figure { margin: 0; }
  .ah-figure img { width: 100%; aspect-ratio: 4/5; object-fit: cover; border-radius: var(--r-lg); border: 1px solid var(--line); box-shadow: var(--shadow-lg); }
  .ah-figure figcaption { margin-top: 0.9rem; font-family: var(--font-serif); font-style: italic; font-size: 0.95rem; color: var(--ink-mute); line-height: 1.5; }

  .about-stats { padding-block: 2rem; background: var(--brand); color: #f3ead4; }
  :root[data-theme='dark'] .about-stats { background: var(--bg-sunk); color: var(--ink); border-block: 1px solid var(--line); }
  .about-stats ul { display: flex; flex-wrap: wrap; justify-content: space-around; gap: 1.5rem; list-style: none; }
  .about-stats li { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .as-v { font-size: var(--step-3); font-weight: 500; line-height: 1; color: #fff; }
  :root[data-theme='dark'] .as-v { color: var(--brand-light); }
  .as-l { font-size: 0.82rem; margin-top: 0.4rem; opacity: 0.85; }

  .about-story .sec-head { text-align: center; margin-bottom: 2.8rem; }
  .story-list { display: flex; flex-direction: column; gap: 1.2rem; max-width: 52rem; margin-inline: auto; }
  .story-row { display: grid; grid-template-columns: 9rem 1fr; gap: 1.5rem; padding: 1.8rem; background: var(--card); border: 1px solid var(--line); border-radius: var(--r-lg); }
  .sr-mark { display: flex; flex-direction: column; border-right: 1.5px dashed var(--dashed); }
  .sr-n { font-size: var(--step-2); color: var(--gold); font-weight: 500; line-height: 1; }
  .sr-t { font-size: 0.85rem; color: var(--ink-mute); font-weight: 700; margin-top: 0.3rem; }
  .sr-h { font-size: var(--step-1); color: var(--ink-strong); font-weight: 800; line-height: 1.4; letter-spacing: -0.02em; }
  .sr-b { margin-top: 0.7rem; color: var(--ink-soft); line-height: 1.7; }

  .about-proof { background: var(--bg-soft); border-block: 1px solid var(--line); }
  .about-proof-inner { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem,5vw,3.5rem); align-items: center; }
  .ap-copy .h2 { margin-top: 0.6rem; }
  .ap-copy .lead { margin-top: 1rem; margin-bottom: 1.2rem; }
  .ap-media { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .ap-media img { width: 100%; aspect-ratio: 3/4; object-fit: cover; border-radius: var(--r-md); border: 1px solid var(--line); box-shadow: var(--shadow-sm); }
  .ap-media img:first-child { margin-top: 1.5rem; }

  .av-card { text-align: center; max-width: 44rem; margin-inline: auto; padding: clamp(2rem,5vw,3.5rem); background: var(--card); border: 1.5px dashed var(--dashed); border-radius: var(--r-xl); }
  .av-mark { color: var(--brand); display: inline-flex; }
  .av-card .h2 { margin-top: 1rem; }
  .av-lead { margin-top: 1.2rem; font-size: var(--step-1); color: var(--ink-soft); line-height: 1.7; }
  .av-give { margin-top: 1.4rem; padding-top: 1.4rem; border-top: 1px solid var(--line); color: var(--ink); }
  .av-give strong { color: var(--gold-ink); }

  .about-biz { padding-block: var(--space-2xl); }
  .biz-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem 2rem; padding-bottom: 2rem; border-bottom: 1.5px dashed var(--dashed); }
  .biz-grid dt { font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-mute); font-weight: 800; margin-bottom: 0.3rem; }
  .biz-grid dd { color: var(--ink-strong); font-weight: 600; }
  .biz-grid a { color: var(--link); }
  .biz-cta { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 2rem; justify-content: center; }

  @media (max-width: 900px) {
    .about-hero-inner { grid-template-columns: 1fr; }
    .ah-figure { max-width: 22rem; order: -1; }
    .about-proof-inner { grid-template-columns: 1fr; }
    .story-row { grid-template-columns: 1fr; gap: 1rem; }
    .sr-mark { flex-direction: row; gap: 0.6rem; align-items: baseline; border-right: none; border-bottom: 1.5px dashed var(--dashed); padding-bottom: 0.8rem; }
    .biz-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) { .biz-grid { grid-template-columns: 1fr; } }
</style>
