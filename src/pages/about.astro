---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/site';

const sections = [
  {
    h: '나는 누구인가',
    body: [
      '저는 조피스입니다.',
      '마케팅, 콘텐츠 제작, AI 영상 제작, 홈페이지 제작을 하고 있습니다. 현재는 세차의고수 본사 마케팅과 운영을 맡으며, 노터치 세차 매장들이 더 잘 팔리고 더 안정적으로 운영될 수 있도록 돕고 있습니다.',
      '하지만 이 블로그에서 가장 먼저 보여주고 싶은 것은 능력이 아니라 사람입니다.',
    ],
  },
  {
    h: '왜 기록하는가',
    body: [
      '저는 좋은 사람이 되고 싶습니다. 정직하게 일하고 싶고, 배운 것을 실제 행동으로 옮기고 싶고, 약한 사람에게 불리한 방식으로 돈 벌고 싶지 않습니다.',
      '피스노트는 그런 방향으로 살고 있는지 스스로 점검하기 위해 만든 기록장입니다. 잘 보이려는 기록이 아니라, 부끄럽지 않게 살고 있는지 확인하려는 기록입니다.',
    ],
  },
  {
    h: '내가 하는 일',
    body: ['마케팅과 콘텐츠, AI 영상 제작, 홈페이지 제작. 그리고 세차의고수 본사의 마케팅과 운영. 화려한 결과보다, 점주와 고객이 실제로 나아지는 구조를 만드는 일에 더 마음을 씁니다.'],
  },
  {
    h: '내가 배우는 것',
    body: ['AI 도구(Cursor·Claude·GPT), 홈페이지 구조 설계, 쇼핑몰 운영, 노터치 세차 기계의 구조까지. 도구는 계속 바뀌니, 배우고 고치는 걸 부끄러워하지 않으려고 합니다.'],
  },
  {
    h: '내가 중요하게 생각하는 것',
    body: ['기술보다 태도. 잘 보이는 것보다 부끄럽지 않은 것. 한 번의 이득보다 오래 신뢰받는 방식. 자세한 기준은 ', null],
  },
  {
    h: '함께 일할 수 있는 것',
    body: ['마케팅 상담, 콘텐츠 제작, AI 활용, 홈페이지 제작, 강의와 커뮤니티 운영. 다만 과장해서 팔거나, 사람을 속이거나, 약한 사람에게 불리한 방식의 일은 하지 않습니다.'],
  },
];
---

<BaseLayout title="소개" description={SITE.description}>
  <section class="about">
    <div class="wrap measure">
      <h1 class="page-title">소개</h1>
      <p class="about-slogan">“{SITE.slogan}”</p>

      <div class="about-body">
        {sections.map((s) => (
          <section class="ab-sec">
            <h2 class="ab-h">{s.h}</h2>
            {s.body.map((p) => (
              p === null
                ? (<p class="ab-p"><a href="/standards">나의 기준</a> 페이지에 적어두었습니다.</p>)
                : (<p class="ab-p">{p}</p>)
            ))}
          </section>
        ))}

        <section class="ab-sec">
          <h2 class="ab-h">연락처</h2>
          <p class="ab-p">함께 일하거나 이야기 나누고 싶다면 <a href={`mailto:${SITE.email}`}>{SITE.email}</a> 또는 <a href="/contact">문의 페이지</a>로 연락 주세요.</p>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about { padding-top: clamp(2rem, 4vw, 3rem); }
  .page-title { font-size: var(--step-4); font-weight: 800; letter-spacing: -0.04em; color: var(--ink-strong); }
  .about-slogan { margin-top: 0.9rem; font-family: var(--font-serif); font-style: italic; font-size: 1.25rem; color: var(--color-primary-ink); padding-bottom: 1.5rem; border-bottom: 1px solid var(--line); }
  .about-body { margin-top: 2rem; display: flex; flex-direction: column; gap: 2rem; }
  .ab-sec {}
  .ab-h { font-size: 1.2rem; font-weight: 800; color: var(--ink-strong); margin-bottom: 0.8rem; letter-spacing: -0.02em; }
  .ab-p { font-size: 1.07rem; line-height: 1.85; color: var(--ink-soft); margin-bottom: 0.7rem; }
  .ab-p a { color: var(--color-primary); font-weight: 600; text-decoration: underline; text-underline-offset: 3px; text-decoration-color: color-mix(in srgb, var(--color-primary) 40%, transparent); }
  .ab-p a:hover { text-decoration-color: currentColor; }
</style>
