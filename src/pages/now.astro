---
import BaseLayout from '../layouts/BaseLayout.astro';

// 이 페이지는 자주 바꿔주세요. (Sveltia CMS 또는 직접 수정)
const lastUpdated = '2026년 6월 25일';
const focus = [
  { t: 'AI 영상 + 실사 합성 작업', d: '소상공인 제품 홍보 영상 몇 건을 동시에. “예쁨”보다 “문의”를 기준으로 컷을 고르는 중.' },
  { t: '대전 마케팅 프로젝트, 계속', d: '무료 컨설팅으로 만난 사장님들의 after를 기록으로 남기는 일. 자랑이 아니라 증거로.' },
  { t: '이 블로그 ‘조피스의 기록’', d: '매일 한 줄씩. 일·생각·일상·맛집·여행을 미화 없이 쌓는 중. 지금 보고 계신 이곳이요.' },
];
const notDoing = [
  '무조건 매출을 보장한다는 약속 — 못 하니까요.',
  '가격과 제공 범위를 숨기는 일 — 그건 평화가 아니라서요.',
  '연락 잘 안 되는 대량 외주 — 혼자 감당할 만큼만.',
];
const intoNow = [
  { k: '읽는 것', v: '브랜딩과 글쓰기에 관한 에세이들 — “계속 쓰는 사람이 작가다”라는 문장에 기대어.' },
  { k: '쓰는 도구', v: 'AI 영상 생성 도구 + 오래 쓴 편집기. 도구는 바뀌어도 고르는 눈은 그대로.' },
  { k: '요즘 마음', v: '혼자 일하는 외로움과 자유 사이. 그래도 누군가의 가게가 잘되는 걸 보면 다시 책상으로.' },
];
---

<BaseLayout title="Now" description="조피스가 지금 집중하는 일과 근황. 자주 바뀌는, 가장 살아있는 페이지.">
  <section class="now">
    <div class="wrap measure">
      <span class="kicker kicker--caps">/now</span>
      <h1 class="h1 display now-title">요즘의 저는</h1>
      <p class="now-intro lead">
        오랜만에 만난 친구에게 근황을 전하듯 적는 페이지예요. 그래서 자주 바뀝니다.
        명함을 보고 들어오셨다면, 여기가 지금의 저와 가장 가깝습니다.
      </p>
      <p class="now-updated">마지막 업데이트 · <span class="num">{lastUpdated}</span> · 대전에서</p>

      <div class="now-block">
        <h2 class="now-h">지금 집중하는 일</h2>
        <ul class="now-list" role="list">
          {focus.map((f) => (
            <li class="now-item reveal"><span class="ni-dot" aria-hidden="true"></span><div><b>{f.t}</b><span>{f.d}</span></div></li>
          ))}
        </ul>
      </div>

      <div class="now-block">
        <h2 class="now-h">지금은 하지 않는 것</h2>
        <ul class="now-not" role="list">
          {notDoing.map((n) => (<li class="reveal">✕ {n}</li>))}
        </ul>
      </div>

      <div class="now-block">
        <h2 class="now-h">요즘의 결</h2>
        <dl class="now-into">
          {intoNow.map((x) => (<div class="reveal"><dt>{x.k}</dt><dd>{x.v}</dd></div>))}
        </dl>
      </div>

      <p class="now-foot">
        이 페이지는 <a href="https://nownownow.com/about" rel="noopener noreferrer" target="_blank" class="u-line">/now 페이지 운동</a>에서 영감을 받았습니다.
        오래 머물지 않아요. 곧 또 바뀝니다.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .now { padding-top: clamp(2rem, 4vw, 3.5rem); }
  .now-title { margin-top: 0.6rem; }
  .now-intro { margin-top: 1rem; }
  .now-updated { margin-top: 1.2rem; font-size: 0.88rem; color: var(--gold-ink); font-weight: 600; padding-bottom: 1.5rem; border-bottom: 1.5px dashed var(--dashed); }
  .now-block { margin-top: 2.5rem; }
  .now-h { font-size: var(--step-1); color: var(--ink-strong); font-weight: 800; margin-bottom: 1.2rem; letter-spacing: -0.02em; }
  .now-list { display: flex; flex-direction: column; gap: 1.1rem; }
  .now-item { display: flex; gap: 1rem; }
  .ni-dot { flex: none; width: 9px; height: 9px; margin-top: 0.55rem; border-radius: 50%; background: var(--brand); box-shadow: 0 0 0 4px color-mix(in srgb, var(--brand) 18%, transparent); }
  .now-item b { color: var(--ink-strong); font-size: 1.05rem; }
  .now-item span { display: block; color: var(--ink-soft); margin-top: 0.25rem; line-height: 1.6; }
  .now-not { display: flex; flex-direction: column; gap: 0.7rem; }
  .now-not li { color: var(--ink-soft); padding: 0.7rem 1rem; background: var(--bg-soft); border-radius: var(--r-sm); border-left: 3px solid var(--terra); }
  .now-into { display: flex; flex-direction: column; gap: 1rem; }
  .now-into div { display: grid; grid-template-columns: 7rem 1fr; gap: 1rem; padding-bottom: 1rem; border-bottom: 1px dashed var(--dashed); }
  .now-into dt { font-weight: 800; color: var(--gold-ink); font-size: 0.92rem; }
  .now-into dd { color: var(--ink-soft); line-height: 1.6; }
  .now-foot { margin-top: 2.5rem; font-size: 0.9rem; color: var(--ink-mute); line-height: 1.6; }
  .now-foot a { color: var(--link); }
  @media (max-width: 520px) { .now-into div { grid-template-columns: 1fr; gap: 0.3rem; } }
</style>
