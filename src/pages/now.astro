---
import BaseLayout from '../layouts/BaseLayout.astro';

// 이 페이지는 자주 바꿔주세요.
const updated = '2026.06.26';
const focusing = [
  '개인 브랜딩 블로그 피스노트 개선',
  '세차의고수 공식 스토어 구조 개선',
  'AI 영상 제작 시스템화',
  '마케팅 콘텐츠 정리',
];
const learning = [
  'Cursor / Claude / GPT 활용',
  '홈페이지 구조 설계',
  '카페24 쇼핑몰',
  '노터치 세차기계 구조',
  'AI 영상 캐릭터 일관성',
];
const making = [
  '피스노트',
  '세차의고수 공식 스토어',
  'AI 드라마 캐릭터 시스템',
  '창업자/마케터 커뮤니티 자료',
];
const paused = [
  '지금은 잠시 멈춰둔 프로젝트들 — 멈춘 것도 기록으로 남깁니다.',
];
const blocks = [
  { t: '요즘 집중하는 것', items: focusing, k: 'focus' },
  { t: '배우고 있는 것', items: learning, k: 'learn' },
  { t: '만들고 있는 것', items: making, k: 'make' },
  { t: '잠시 멈춘 것', items: paused, k: 'pause' },
];
---

<BaseLayout title="지금 하는 일" description="조피스가 지금 집중하는 일·배우는 것·만드는 것. 자주 바뀌는, 가장 살아있는 페이지.">
  <section class="now">
    <div class="wrap measure">
      <h1 class="page-title">지금 하는 일</h1>
      <p class="now-note">오랜만에 만난 사람에게 근황을 전하듯 적는 페이지예요. 그래서 자주 바뀝니다.</p>
      <p class="now-updated">업데이트 · <span class="num">{updated}</span></p>

      <div class="now-blocks">
        {blocks.map((b) => (
          <div class={`nb nb--${b.k}`}>
            <h2 class="nb-title">{b.t}</h2>
            <ul role="list">{b.items.map((it) => (<li>{it}</li>))}</ul>
          </div>
        ))}
      </div>

      <p class="now-foot">
        이 페이지는 <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">/now 페이지</a> 방식에서 영감을 받았습니다. 오래 머물지 않아요. 곧 또 바뀝니다.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .now { padding-top: clamp(2rem, 4vw, 3rem); }
  .page-title { font-size: var(--step-4); font-weight: 800; letter-spacing: -0.04em; color: var(--ink-strong); }
  .now-note { margin-top: 0.8rem; color: var(--ink-soft); font-size: 1.05rem; }
  .now-updated { margin-top: 0.6rem; font-size: 0.9rem; color: var(--color-primary-ink); font-weight: 700; padding-bottom: 1.5rem; border-bottom: 1px solid var(--line); }
  .num { font-variant-numeric: tabular-nums; }
  .now-blocks { margin-top: 1.8rem; display: flex; flex-direction: column; gap: 1.2rem; }
  .nb { padding: 1.5rem 1.6rem; border-radius: var(--r-md); border: 1px solid var(--line); background: var(--card); border-left: 4px solid var(--accent, var(--color-primary)); }
  .nb--focus { --accent: var(--color-primary); }
  .nb--learn { --accent: var(--color-green); }
  .nb--make { --accent: #b88a2e; }
  .nb--pause { --accent: var(--ink-mute); }
  .nb-title { font-size: 1.15rem; font-weight: 800; color: var(--ink-strong); margin-bottom: 0.9rem; letter-spacing: -0.02em; }
  .nb ul { display: flex; flex-direction: column; gap: 0.55rem; }
  .nb li { color: var(--ink-soft); line-height: 1.6; padding-left: 1.1rem; position: relative; }
  .nb li::before { content: ''; position: absolute; left: 0; top: 0.65em; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
  .nb--pause li { color: var(--ink-mute); }
  .now-foot { margin-top: 2rem; font-size: 0.9rem; color: var(--ink-mute); line-height: 1.6; }
  .now-foot a { color: var(--color-primary); }
</style>
