---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts } from '../lib/utils';
import { CATEGORY_ORDER, CATEGORIES } from '../lib/categories';

const posts = await getPublishedPosts();
const counts: Record<string, number> = { all: posts.length };
for (const k of CATEGORY_ORDER) counts[k] = posts.filter((p) => p.data.category === k).length;
---

<BaseLayout title="기록" description="조피스의 모든 기록 — 일상·작업·생각·맛집·여행·성취를 한곳에서.">
  <header class="log-head">
    <div class="wrap">
      <span class="kicker kicker--caps">The stream</span>
      <h1 class="h1 display">기록</h1>
      <p class="lead">매일 한 줄씩 쌓아온 시간. 보고 싶은 결을 골라보세요.</p>

      <div class="log-controls">
        <div class="chips" role="tablist" aria-label="카테고리 필터">
          <button class="chip is-active" data-filter="all" role="tab" aria-selected="true">전체 <span class="chip-c num">{counts.all}</span></button>
          {CATEGORY_ORDER.map((k) => (
            <button class="chip" data-filter={k} role="tab" aria-selected="false" style={`--cat: var(${CATEGORIES[k].colorVar})`}>
              {CATEGORIES[k].emoji} {CATEGORIES[k].name} <span class="chip-c num">{counts[k]}</span>
            </button>
          ))}
        </div>
        <div class="view-toggle" role="group" aria-label="보기 방식">
          <button class="vt-btn is-active" data-view="gallery" aria-label="갤러리 보기" aria-pressed="true">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          </button>
          <button class="vt-btn" data-view="list" aria-label="목록 보기" aria-pressed="false">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
      </div>
    </div>
  </header>

  <section class="log-body">
    <div class="wrap">
      <div class="log-gallery" id="gallery-view">
        {posts.map((post, i) => (
          <div class="log-item" data-cat={post.data.category}>
            <PostCard post={post} variant="default" index={i} />
          </div>
        ))}
      </div>
      <div class="log-list" id="list-view" hidden>
        {posts.map((post, i) => (
          <div class="log-item" data-cat={post.data.category}>
            <PostCard post={post} variant="list" index={i} />
          </div>
        ))}
      </div>
      <p class="log-empty" id="log-empty" hidden>이 코너엔 아직 기록이 없어요. 🌱</p>
    </div>
  </section>
</BaseLayout>

<style>
  .log-head { padding-top: clamp(2rem, 4vw, 3.2rem); padding-bottom: 1.5rem; border-bottom: 1px solid var(--line); }
  .log-head .h1 { margin-top: 0.5rem; }
  .log-head .lead { margin-top: 0.6rem; }
  .log-controls { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-top: 1.8rem; flex-wrap: wrap; }
  .chips { display: flex; flex-wrap: wrap; gap: 0.55rem; }
  .chip-c { font-size: 0.78em; opacity: 0.7; margin-left: 0.15em; }
  .view-toggle { display: flex; gap: 0.25rem; padding: 0.25rem; background: var(--bg-soft); border-radius: var(--r-pill); border: 1px solid var(--line); }
  .vt-btn { display: grid; place-items: center; width: 2.1rem; height: 2.1rem; border-radius: var(--r-pill); color: var(--ink-mute); transition: all var(--dur-fast); }
  .vt-btn.is-active { background: var(--card); color: var(--brand); box-shadow: var(--shadow-sm); }

  .log-body { padding-top: 2.2rem; }
  .log-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }
  .log-item { display: block; }
  .log-item.is-hidden { display: none; }
  .log-empty { text-align: center; color: var(--ink-mute); padding: 3rem; }

  @media (max-width: 900px) { .log-gallery { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .log-gallery { grid-template-columns: 1fr; } .log-controls { flex-direction: column; align-items: flex-start; } }
</style>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip[data-filter]');
  const items = document.querySelectorAll<HTMLElement>('.log-item');
  const empty = document.getElementById('log-empty');
  const gallery = document.getElementById('gallery-view');
  const list = document.getElementById('list-view');
  const vtBtns = document.querySelectorAll<HTMLButtonElement>('.vt-btn');

  let filter = 'all';

  function apply() {
    let visible = 0;
    items.forEach((el) => {
      const match = filter === 'all' || el.dataset.cat === filter;
      el.classList.toggle('is-hidden', !match);
      if (match) visible++;
    });
    // 각 뷰는 동일 항목 2벌이므로 visible/2
    if (empty) empty.hidden = visible > 0;
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => { c.classList.remove('is-active'); c.setAttribute('aria-selected', 'false'); });
      chip.classList.add('is-active'); chip.setAttribute('aria-selected', 'true');
      filter = chip.dataset.filter || 'all';
      apply();
    });
  });

  vtBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const view = btn.dataset.view;
      vtBtns.forEach((b) => { b.classList.remove('is-active'); b.setAttribute('aria-pressed', 'false'); });
      btn.classList.add('is-active'); btn.setAttribute('aria-pressed', 'true');
      if (gallery) gallery.hidden = view !== 'gallery';
      if (list) list.hidden = view !== 'list';
    });
  });

  // URL 해시로 카테고리 진입 지원 (#food 등)
  const hash = location.hash.replace('#', '');
  if (hash) {
    const target = document.querySelector<HTMLButtonElement>(`.chip[data-filter="${hash}"]`);
    target?.click();
  }
</script>
