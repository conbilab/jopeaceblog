---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/site';

const types = ['마케팅 상담', '콘텐츠 제작', 'AI 활용', '홈페이지 제작', '강의/커뮤니티', '기타'];
---

<BaseLayout title="문의" description="함께 일하거나 이야기 나누고 싶은 일이 있다면 연락 주세요.">
  <section class="contact">
    <div class="wrap measure">
      <h1 class="page-title">문의</h1>
      <div class="ct-intro">
        <p>함께 일하거나 이야기 나누고 싶은 일이 있다면 연락 주세요.</p>
        <p>마케팅, 콘텐츠 제작, AI 활용, 홈페이지 제작, 강의, 커뮤니티 운영과 관련된 일을 함께할 수 있습니다.</p>
        <p class="muted">다만 과장해서 팔거나, 사람을 속이거나, 약한 사람에게 불리한 방식의 일은 하고 싶지 않습니다.</p>
      </div>

      <form class="ct-form" id="ct-form" data-email={SITE.email}>
        <div class="row2">
          <label class="field"><span>이름</span><input type="text" name="name" required autocomplete="name" /></label>
          <label class="field"><span>이메일</span><input type="email" name="email" required autocomplete="email" /></label>
        </div>
        <label class="field"><span>문의 유형</span>
          <select name="kind">{types.map((t) => (<option value={t}>{t}</option>))}</select>
        </label>
        <label class="field"><span>문의 내용</span><textarea name="message" rows="6" required></textarea></label>
        <button type="submit" class="btn btn-primary">메일로 보내기</button>
        <p class="ct-hint">버튼을 누르면 메일 앱이 열립니다. 직접 <a href={`mailto:${SITE.email}`}>{SITE.email}</a> 로 보내셔도 됩니다.</p>
      </form>

      <!-- 뉴스레터 (Phase 2에서 구글/카카오 로그인·발송 연동 예정) -->
      <div class="newsletter card">
        <div>
          <p class="nl-title">📮 피스노트 뉴스레터</p>
          <p class="nl-desc">매일 쓰는 “조피스 생각”을 메일로도 보내드릴 예정입니다. 곧 시작해요.</p>
        </div>
        <form class="nl-form" id="nl-form">
          <input type="email" name="email" placeholder="이메일 주소" aria-label="뉴스레터 이메일" />
          <button type="submit" class="btn btn-ghost">신청 (준비 중)</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact { padding-top: clamp(2rem, 4vw, 3rem); }
  .page-title { font-size: var(--step-4); font-weight: 800; letter-spacing: -0.04em; color: var(--ink-strong); }
  .ct-intro { margin-top: 1.2rem; display: flex; flex-direction: column; gap: 0.6rem; font-size: 1.07rem; line-height: 1.8; color: var(--ink-soft); padding-bottom: 1.5rem; border-bottom: 1px solid var(--line); }
  .ct-intro .muted { color: var(--ink-mute); font-size: 1rem; }

  .ct-form { margin-top: 2rem; display: flex; flex-direction: column; gap: 1.1rem; }
  .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }
  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field span { font-size: 0.85rem; font-weight: 700; color: var(--ink-soft); }
  .field input, .field select, .field textarea { font: inherit; font-size: 1rem; padding: 0.75rem 0.9rem; border: 1px solid var(--line-strong); border-radius: var(--r-sm); background: var(--card); color: var(--ink); transition: border-color var(--dur-fast), box-shadow var(--dur-fast); }
  .field input:focus, .field select:focus, .field textarea:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 3px var(--color-primary-soft); }
  .field textarea { resize: vertical; }
  .ct-form .btn { align-self: flex-start; }
  .ct-hint { font-size: 0.85rem; color: var(--ink-mute); }
  .ct-hint a { color: var(--color-primary); }

  .newsletter { margin-top: 2.5rem; padding: 1.6rem 1.8rem; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; border: 1px solid var(--line); border-radius: var(--r-lg); background: var(--color-primary-soft); flex-wrap: wrap; }
  .nl-title { font-weight: 800; color: var(--ink-strong); font-size: 1.05rem; }
  .nl-desc { color: var(--ink-soft); font-size: 0.92rem; margin-top: 0.3rem; max-width: 40ch; }
  .nl-form { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .nl-form input { font: inherit; padding: 0.6rem 0.85rem; border: 1px solid var(--line-strong); border-radius: var(--r-sm); background: var(--card); }

  @media (max-width: 560px) { .row2 { grid-template-columns: 1fr; } }
</style>

<script>
  const form = document.getElementById('ct-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = form.dataset.email || '';
    const f = new FormData(form);
    const subject = `[피스노트 문의] ${f.get('kind')} — ${f.get('name')}`;
    const body = `이름: ${f.get('name')}\n이메일: ${f.get('email')}\n문의 유형: ${f.get('kind')}\n\n${f.get('message')}`;
    window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  });
  const nl = document.getElementById('nl-form');
  nl?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('뉴스레터는 곧 시작합니다. 조금만 기다려 주세요. 🙏');
  });
</script>
