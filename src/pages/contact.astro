---
import BaseLayout from '../layouts/BaseLayout.astro';
import Logo from '../components/Logo.astro';
import { SITE, SOCIAL } from '../lib/site';

const channels = [
  { ic: '✉️', label: '이메일', value: SITE.email, href: `mailto:${SITE.email}`, note: '가장 확실한 연락 방법' },
  { ic: '💬', label: '카카오톡 상담', value: '피스웍스 채널', href: '#', note: '문의·견적은 여기로 (링크 연결 예정)' },
  { ic: '🎬', label: '유튜브', value: '배워서남주는조피디', href: '#', note: 'AI 영상·마케팅 이야기' },
  { ic: '📷', label: '인스타그램', value: '@jopis', href: '#', note: '일상과 작업의 짧은 기록' },
];
---

<BaseLayout title="연락하기" description="명함을 보고 오셨나요? 조피스에게 닿는 모든 길을 한곳에 모았습니다.">
  <section class="contact">
    <div class="wrap">
      <div class="ct-head">
        <span class="ct-mark"><Logo size={52} stroke={2} /></span>
        <span class="kicker">Say hello</span>
        <h1 class="h1 display">명함을 보고 오셨나요?<br/>잘 오셨습니다.</h1>
        <p class="lead ct-lead">
          이 블로그를 다 둘러보셨다면, 이제 저에 대해 꽤 아실 거예요.
          영상·강의·마케팅 구조에 대한 이야기, 또는 그냥 인사도 환영합니다. 무리하게 권하지 않으니 편하게 연락 주세요.
        </p>
      </div>

      <div class="ct-grid">
        {channels.map((c) => {
          const isReal = c.href && c.href !== '#';
          const ext = c.href.startsWith('http');
          const Tag = isReal ? 'a' : 'div';
          return (
            <Tag
              class:list={['ct-card', 'card', { 'is-soon': !isReal }]}
              href={isReal ? c.href : undefined}
              target={ext ? '_blank' : undefined}
              rel={ext ? 'noopener noreferrer' : undefined}
            >
              <span class="ct-ic" aria-hidden="true">{c.ic}</span>
              <span class="ct-label">{c.label}</span>
              <span class="ct-value">{c.value}</span>
              <span class="ct-note">{isReal ? c.note : `${c.note} · 연결 예정`}</span>
            </Tag>
          );
        })}
      </div>

      <div class="ct-foot card card--dashed">
        <div>
          <p class="cf-h">함께 일하고 싶으시다면</p>
          <p class="cf-d">현재 상황을 듣고 가장 합리적인 방식을 추천해드립니다. 맞지 않으면 솔직히 말씀드려요.</p>
        </div>
        <a href={`mailto:${SITE.email}?subject=피스웍스 문의`} class="btn btn-primary">메일로 문의하기 →</a>
      </div>

      <p class="ct-biz">피스웍스 · 대표 조재빈 · 사업자등록 731-24-00997 · 대전</p>
    </div>
  </section>
</BaseLayout>

<style>
  .contact { padding-top: clamp(2rem, 4vw, 3.5rem); }
  .ct-head { max-width: 46rem; }
  .ct-mark { color: var(--brand); display: inline-flex; margin-bottom: 1rem; }
  .ct-head .h1 { margin-top: 0.6rem; }
  .ct-lead { margin-top: 1.2rem; max-width: 44ch; }
  .ct-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.2rem; margin-top: 2.5rem; }
  .ct-card { display: flex; flex-direction: column; gap: 0.3rem; padding: 1.5rem 1.6rem; }
  .ct-ic { font-size: 1.6rem; margin-bottom: 0.4rem; }
  .ct-label { font-size: 0.8rem; color: var(--ink-mute); font-weight: 700; letter-spacing: 0.03em; }
  .ct-value { font-size: var(--step-1); font-weight: 800; color: var(--ink-strong); }
  .ct-card:hover .ct-value { color: var(--brand); }
  .ct-note { font-size: 0.85rem; color: var(--ink-soft); margin-top: 0.2rem; }
  .ct-card.is-soon { cursor: default; opacity: 0.78; }
  .ct-card.is-soon:hover { transform: none; box-shadow: var(--shadow-sm); border-color: var(--line); }
  .ct-card.is-soon:hover .ct-value { color: var(--ink-strong); }
  .ct-foot { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; padding: 1.8rem 2rem; margin-top: 1.8rem; background: var(--bg-soft); flex-wrap: wrap; }
  .cf-h { font-weight: 800; font-size: var(--step-1); color: var(--ink-strong); }
  .cf-d { color: var(--ink-soft); margin-top: 0.3rem; max-width: 40ch; }
  .ct-biz { margin-top: 2rem; font-size: 0.82rem; color: var(--ink-mute); text-align: center; }
  @media (max-width: 600px) { .ct-grid { grid-template-columns: 1fr; } }
</style>
