---
import BaseLayout from '../layouts/BaseLayout.astro';

const now = {
  집중하는_것: ['홈서버 개인 AI OS 구축', '세차의고수 온라인 마케팅(80개 매장)', '새 사업 아이템 MVP', '피스노트 개선'],
  배우는_중: ['AI 에이전트 설계·Python 오케스트레이션', '홈서버·리눅스·Docker', 'Cursor·Claude·GPT 활용', '마케팅 이론·트렌드(구독경제 등)'],
  만드는_중: ['콘텐츠 제작 에이전트 자동화', '쇼핑몰 자동화 시스템', '업무 자동화 10여 개', '아이디어테이블 커뮤니티'],
};
const nowCols = [
  { h: '집중하는 것', items: now.집중하는_것 },
  { h: '배우는 중', items: now.배우는_중 },
  { h: '만드는 중', items: now.만드는_중 },
];

const stats = [
  { v: '12년', l: '영상 제작 현장' },
  { v: '500편+', l: '만든 영상' },
  { v: '262편', l: '꾸준히 쓴 기록' },
  { v: '200명+', l: '마케팅 컨설팅' },
];

const domains = [
  { n: '영상 제작', b: '12년간 현장에서. 웹드라마 촬영감독·조연출, 아이돌 뮤직비디오·웹예능, 홍보·다큐·광고·방송 중계까지.', i: ['웹드라마 촬영감독·조연출', '아이돌 뮤직비디오', '아이돌 웹예능 촬영', '50분 다큐멘터리', '기업 홍보·제품 광고', '단편영화'] },
  { n: '유튜브 · 콘텐츠', b: '채널 기획·제작부터 알고리즘·썸네일·수익화까지 파고들고, 그걸 다시 가르쳤다.', i: ['콘텐츠 기획·연출', '썸네일·제목 최적화', '알고리즘 연구', '수익화 구조 설계'] },
  { n: '마케팅 · 컨설팅', b: '지금까지 200명이 넘는 분들에게 컨설팅. 공부한 걸 토대로 ‘8단계 마케팅 이론’을 직접 만들었다.', i: ['8단계 마케팅 이론 개발', '200명+ 마케팅 컨설팅', '퍼스널 브랜딩', '키워드·SNS 광고'] },
  { n: '강의 · 교육', b: 'KAIST IR센터 등 대학·공공기관 출강. 예비창업 심사위원·창업 멘토까지.', i: ['KAIST IR센터 출강', '예비창업 심사위원', '창업 멘토', '유튜브·영상 제작 강의'] },
  { n: '글쓰기 · 창작', b: '초단편 소설을 쓰고, 시나리오를 파고, 블로그에 262편을 연재했다.', i: ['초단편 소설 창작', '시나리오 연구', '스토리텔링', '블로그 262편'] },
  { n: '세차의고수', b: '노터치 세차 프랜차이즈 본사 마케팅·운영. 0개 매장에서 80개 매장까지 온라인 마케팅을 진행했고, 지금도 진행 중.', i: ['0→80개 매장 온라인 마케팅', '공식 스토어 구축', '정기배송 마케팅', '가맹점 운영 지원'] },
  { n: 'AI · 자동화', b: '말로 시켜 만든 편집 에이전트부터 24시간 도는 홈서버 AI OS까지. 클로드 코드 플러그인 12종도 배포.', i: ['캡컷 에이전트 DraftCut(31편)', '홈서버 개인 AI OS', '클로드 코드 플러그인 12종', '업무 자동화 10+'] },
  { n: '사업 · 시스템', b: '정보를 내 사업 원칙으로 바꾸는 시스템을 짜고, 새 사업 아이템 MVP를 계속 만든다.', i: ['8단계 마케팅 이론(J-Biz)', '정보→사업원칙 시스템', '새 사업 MVP', '사업계획·창업지원 PT'] },
];

const market8 = [
  { n: 'Foundation', t: '기초·마인드셋', d: '막연한 부자가 아니라 ‘연봉 1억’을 설계도로 그리는 단계. 생계형에서 1인 기업가로.' },
  { n: 'Product', t: '상품 본질·차별화', d: '‘침대가 아니라 숙면을 판다’. 제품이 아니라 문제 해결·가치를 파는 재정의.' },
  { n: 'Persona', t: '타겟 해부', d: '‘2030 여성’ 말고, 살 사람 단 한 명을 몽타주처럼. 모두에게 팔면 아무에게도 못 판다.' },
  { n: 'Economics', t: '마진·가격', d: '감성 빼고 숫자만. 매출은 허영, 수익은 현실, 현금은 산소.' },
  { n: 'Traffic', t: '고객 유입', d: '계산기 대신 확성기. 채널·키워드·콘텐츠로 손님을 끌어오는 전략.' },
  { n: 'Retention', t: '재구매·CRM', d: '신규는 빚, 유지는 자산. 기존 고객을 자산화하는 재구매 시스템.' },
  { n: 'Scale-up', t: '객단가·확장', d: '많이 파는 건 하수, 비싸게 파는 게 고수. 지식·경험의 고가 상품화.' },
  { n: 'Exit', t: '자동화·엑싯', d: '사장 없이도 굴러가게. AI·자동화로 시스템을 만들고, 팔거나 캐시카우로.' },
];

const systems = [
  { t: '캡컷 에이전트 · DraftCut', s: '완성', d: '토킹 영상만 넣으면 무음컷·타이트컷·전사자막·다국어 번역·AI이미지까지 얹은 편집 프로젝트를 자동 생성. 말로 시켜 31편에 걸쳐 만든 편집 자동화.' },
  { t: '홈서버 개인 AI OS', s: '만드는중', d: '텔레그램으로 명령하면 라우팅하고, 옵시디언 기억을 검토해, 파이썬이 실행하는 24시간 개인 업무 운영체제(Hermes+OpenClaw).' },
  { t: '콘텐츠 제작 에이전트 자동화', s: '업데이트중', d: '홈서버 위에서 도는 콘텐츠 워커들(수집·블로그·이미지·영상·스레드). 계속 확장 중.' },
  { t: '콘텐츠 재가공 자동화', s: '완성', d: '브리프 하나로 네이버블로그·인스타·스레드·워드프레스·유튜브 5개 플랫폼 초안을 한 번에.' },
  { t: '쇼핑몰 자동화 시스템', s: '만드는중', d: '쇼핑몰 주문·운영을 자동으로. 손이 덜 가게 만드는 중.' },
  { t: '창고 재고 맞춤형 시스템', s: '관리중', d: '재고를 상황에 맞게 관리하는 맞춤형 시스템. 만들어서 계속 업데이트.' },
  { t: '업무 자동화 10여 개', s: '완성', d: '썸네일·SNS 콘텐츠·스레드 답글·블로그 이미지 생성 등 반복 업무를 자동화.' },
  { t: '새 사업 아이템 MVP', s: '진행중', d: '지금도 새로운 사업 아이템의 MVP를 만들고 있어요.' },
];

const projects = [
  { t: '조피스의 아이디어테이블', active: true, o: '창업자·마케터가 실제로 만나 아이디어와 도움을 주고받는 커뮤니티. 요즘 제일 뜨거운 자리예요.', r: '기획·진행·연결', link: 'https://jopeace-ideatable.vercel.app/', l: '모으는 것보다 “오길 잘했다”고 느끼게 하는 게 핵심. 작게 모여 깊게 나눌 때 다들 만족했어요.' },
  { t: '개인 브랜딩 블로그 피스노트', active: true, o: '제가 겪고 배운 것을 진심으로 적어두는 공개 기록 블로그.', r: '기획·글쓰기·운영', l: '공개로 쓴다는 건 실패와 반성도 남긴다는 뜻. 솔직하고 구체적인 글에 사람들이 반응했어요.' },
  { t: '세차의고수 공식 스토어', active: true, o: '가맹점주가 소모품을 한 곳에서 주문하도록 공식 스토어를 만들고 운영합니다.', r: '스토어 기획·상세·운영', l: '선택지가 많을수록 덜 샀어요. “이 상황엔 이거”라고 정리해주는 게 더 도움이 됐습니다.' },
  { t: '노터치 세차 정기배송 구조', active: true, o: '세차 소모품을 정기적으로 받아보게 만들어 매장 운영이 끊기지 않도록 돕습니다.', r: '흐름 설계·운영', l: '핵심은 자동 발송이 아니라 “안 끊기겠구나” 하는 안심. 혜택보다 약속을 지키는 운영이 먼저.' },
];

const stCls = (s: string) => (s === '완성' ? 'st-done' : s === '만드는중' || s === '진행중' ? 'st-making' : 'st-mng');
---

<BaseLayout title="하는 일" description="조피스(조재빈)가 그동안 해온 일 — 영상·마케팅·강의·글쓰기·세차의고수·AI 자동화, 8단계 마케팅 이론과 자동화 시스템.">
  <section class="doing">
    <div class="wrap">
      <span class="eyebrow">하는 일</span>
      <h1 class="pg-h">그동안, 다양하게 일했습니다.</h1>

      <!-- 지금은 -->
      <div class="nowbox">
        <div class="nh"><b>지금은</b><span class="upd">업데이트 2026.07</span></div>
        <div class="nowcols">
          {nowCols.map((c) => (
            <div>
              <h4>{c.h}</h4>
              <ul>{c.items.map((x) => (<li>{x}</li>))}</ul>
            </div>
          ))}
        </div>
      </div>

      <!-- 실적 -->
      <div class="stats">
        {stats.map((s) => (<div class="stat"><div class="v">{s.v}</div><div class="l">{s.l}</div></div>))}
      </div>

      <!-- 해온 일의 폭 -->
      <h2 class="sec">해온 일의 폭</h2>
      <div class="domains">
        {domains.map((d) => (
          <div class="dom">
            <h4>{d.n}</h4>
            <p class="bl">{d.b}</p>
            <div class="it">{d.i.map((x) => (<span>{x}</span>))}</div>
          </div>
        ))}
      </div>

      <!-- 8단계 마케팅 이론 -->
      <h2 class="sec">8단계 마케팅 이론</h2>
      <p class="sec-lead">소상공인·1인기업가를 ‘위대한 사업가’로 만드는, 제가 직접 만든 커리큘럼(400문항).</p>
      <div class="steps">
        {market8.map((s, i) => (
          <div class="step">
            <span class="step-n">{i + 1}</span>
            <div><b>{s.n} · {s.t}</b><p>{s.d}</p></div>
          </div>
        ))}
      </div>

      <!-- 자동화 시스템 -->
      <h2 class="sec">만들고 있는 것 · 자동화 시스템</h2>
      <div class="systems">
        {systems.map((s) => (
          <div class="sys">
            <div class="sys-h"><span class="sys-t">{s.t}</span><span class={`pill ${stCls(s.s)}`}>{s.s}</span></div>
            <p class="sys-d">{s.d}</p>
          </div>
        ))}
      </div>

      <!-- 대표 프로젝트 -->
      <h2 class="sec">대표 프로젝트</h2>
      <div class="projs">
        {projects.map((p) => (
          <div class="proj">
            <div class="proj-h">
              <span class="proj-t">{p.t}</span>
              <span class={`pill ${p.active ? 'st-making' : 'st-mng'}`}>{p.active ? '진행 중' : '잠시 멈춤'}</span>
            </div>
            <p class="proj-o">{p.o}</p>
            <p class="proj-meta">역할 · {p.r}{p.link && (<> · <a href={p.link} target="_blank" rel="noopener noreferrer">사이트 바로가기 →</a></>)}</p>
            <p class="proj-learn"><b>배운 것 —</b> {p.l}</p>
          </div>
        ))}
      </div>

      <div class="contact-box">마케팅 · 콘텐츠 · AI · 홈페이지 · 강의 — 함께 일하고 싶다면 <b>jopd_prod@kakao.com</b> 또는 <a href="/contact">문의 페이지</a>로.</div>
    </div>
  </section>
</BaseLayout>

<style>
  .doing { padding-top: clamp(2rem, 4vw, 3rem); }
  .eyebrow { font-family: var(--font-ui); font-size: 0.76rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-primary); }
  .pg-h { font-size: var(--step-4); font-weight: 800; letter-spacing: -0.04em; color: var(--ink-strong); margin-top: 0.6rem; line-height: 1.12; }

  /* 지금은 (다크 카드) */
  .nowbox { margin-top: 2rem; background: #1c1913; color: #ece3cf; border-radius: var(--r-lg); padding: clamp(1.4rem, 3vw, 2rem); }
  .nh { display: flex; align-items: baseline; gap: 0.7rem; margin-bottom: 1.2rem; }
  .nh b { font-size: 1.2rem; color: #fbf7ec; font-weight: 800; }
  .upd { font-family: var(--font-ui); font-size: 0.72rem; letter-spacing: 0.06em; color: #9a9280; }
  .nowcols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .nowcols h4 { font-size: 0.9rem; font-weight: 800; color: var(--color-primary); margin-bottom: 0.7rem; }
  .nowcols ul { list-style: none; margin: 0; padding: 0; }
  .nowcols li { color: #d8cfbb; font-size: 0.95rem; line-height: 1.55; padding-left: 0.95rem; position: relative; margin-bottom: 0.45rem; word-break: keep-all; }
  .nowcols li::before { content: ''; position: absolute; left: 0; top: 0.6em; width: 5px; height: 5px; border-radius: 50%; background: var(--color-primary); opacity: 0.8; }

  /* 실적 */
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 1.5rem; }
  .stat { text-align: center; padding: 1.3rem 0.6rem; background: var(--bg-soft); border: 1px solid var(--line); border-radius: var(--r-card); }
  .stat .v { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; color: var(--color-primary-ink); letter-spacing: -0.03em; }
  .stat .l { font-size: 0.85rem; color: var(--ink-mute); margin-top: 0.3rem; }

  .sec { font-size: var(--step-2); font-weight: 800; letter-spacing: -0.03em; color: var(--ink-strong); margin-top: 3rem; margin-bottom: 1.2rem; padding-bottom: 0.6rem; border-bottom: 2px solid var(--line); }
  .sec-lead { margin-top: -0.7rem; margin-bottom: 1.4rem; color: var(--ink-mute); font-size: 0.98rem; }

  /* 경력 도메인 */
  .domains { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.1rem; }
  .dom { padding: 1.4rem; background: var(--card); border: 1px solid var(--line); border-radius: var(--r-card); }
  .dom h4 { font-size: 1.1rem; font-weight: 800; color: var(--ink-strong); margin-bottom: 0.5rem; }
  .dom .bl { font-size: 0.96rem; line-height: 1.7; color: var(--ink-soft); word-break: keep-all; }
  .dom .it { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.9rem; }
  .dom .it span { font-size: 0.8rem; font-weight: 600; color: var(--ink-mute); background: var(--bg-soft); border: 1px solid var(--line); border-radius: var(--r-pill); padding: 0.3em 0.7em; }

  /* 8단계 */
  .steps { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.9rem; }
  .step { display: flex; gap: 0.9rem; padding: 1.2rem; background: var(--card); border: 1px solid var(--line); border-radius: var(--r-card); }
  .step-n { flex: none; width: 2rem; height: 2rem; display: grid; place-items: center; border-radius: 50%; background: var(--color-primary); color: #fff; font-weight: 800; font-size: 0.95rem; font-family: var(--font-ui); }
  .step b { color: var(--ink-strong); font-size: 1rem; font-weight: 800; }
  .step p { color: var(--ink-soft); font-size: 0.92rem; line-height: 1.6; margin-top: 0.3rem; word-break: keep-all; }

  /* 시스템 */
  .systems { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.9rem; }
  .sys { padding: 1.3rem; background: var(--card); border: 1px solid var(--line); border-radius: var(--r-card); }
  .sys-h { display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; margin-bottom: 0.5rem; }
  .sys-t { font-size: 1.02rem; font-weight: 800; color: var(--ink-strong); }
  .sys-d { font-size: 0.92rem; line-height: 1.65; color: var(--ink-soft); word-break: keep-all; }

  /* 프로젝트 */
  .projs { display: flex; flex-direction: column; gap: 1rem; }
  .proj { padding: 1.5rem; background: var(--card); border: 1px solid var(--line); border-radius: var(--r-card); }
  .proj-h { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.5rem; }
  .proj-t { font-size: 1.15rem; font-weight: 800; color: var(--ink-strong); }
  .proj-o { font-size: 1rem; line-height: 1.7; color: var(--ink-soft); }
  .proj-meta { font-size: 0.88rem; color: var(--ink-mute); margin-top: 0.6rem; }
  .proj-meta a { color: var(--color-primary); font-weight: 700; }
  .proj-learn { font-size: 0.92rem; line-height: 1.65; color: var(--ink-soft); margin-top: 0.7rem; padding-top: 0.7rem; border-top: 1px dashed var(--line-strong); word-break: keep-all; }
