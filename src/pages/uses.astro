---
import BaseLayout from '../layouts/BaseLayout.astro';

const groups = [
  {
    title: '촬영 · 영상',
    icon: '🎥',
    items: [
      ['카메라 / 짐벌', '현장에 따라 바뀌지만, 무겁지 않게. 장비보다 구도와 빛이 먼저라고 믿습니다.'],
      ['조명', '자연광 우선. 부족하면 작은 LED 하나로 충분할 때가 많아요.'],
      ['마이크', '영상의 절반은 소리. 인터뷰엔 핀마이크를 꼭 챙깁니다.'],
    ],
  },
  {
    title: '편집 · 후반',
    icon: '✂️',
    items: [
      ['편집 프로그램', '오래 손에 익은 편집기. 도구는 바뀌어도 컷을 고르는 눈은 그대로.'],
      ['색보정 · 자막', '브랜드 톤에 맞춘 색과, 모바일에서도 읽히는 자막 크기.'],
      ['음악 · 효과음', '라이선스 안전한 소스만. 0.5초의 타이밍이 영상의 인상을 바꿉니다.'],
    ],
  },
  {
    title: 'AI · 마케팅',
    icon: '🤖',
    items: [
      ['AI 영상 생성', '컷을 빠르게 뽑되, 깨진 손·글자는 사람이 골라냅니다.'],
      ['AI 글쓰기 보조', '초안의 재료로만. 본문은 결국 제 문장으로 — 정직함이 신뢰니까요.'],
      ['퍼널 · 자동화', '랜딩페이지·카카오 상담·후속 메시지까지 “문의되는 구조”로.'],
    ],
  },
  {
    title: '일상 · 작업 환경',
    icon: '🪑',
    items: [
      ['작업 공간', '사무실과 동네 카페를 오갑니다. 글은 카페에서 더 잘 써져요.'],
      ['기록 도구', '떠오르면 바로 메모. 이 블로그도 그 메모들이 자라서 된 곳입니다.'],
      ['이 블로그', 'Astro로 만든 정적 사이트 + Pretendard·Fraunces. 자세한 건 콜로폰에서.'],
    ],
  },
];
---

<BaseLayout title="쓰는 것들 (uses)" description="조피스가 일하고 기록할 때 쓰는 장비와 도구 — 장비보다 원칙이 먼저입니다.">
  <header class="uses-head">
    <div class="wrap measure">
      <span class="kicker kicker--caps">/uses</span>
      <h1 class="h1 display">쓰는 것들</h1>
      <p class="lead">자주 받는 질문이라 정리해 둡니다. 다만 미리 말씀드리면 — <strong>장비가 결과를 만들지 않습니다.</strong> 무엇을 버릴지 아는 눈이 먼저예요.</p>
    </div>
  </header>

  <section class="uses-body">
    <div class="wrap measure">
      {groups.map((g, i) => (
        <div class="uses-group reveal" data-delay={String((i % 4) + 1)}>
          <h2 class="ug-title"><span aria-hidden="true">{g.icon}</span> {g.title}</h2>
          <dl class="ug-list">
            {g.items.map(([k, v]) => (<div><dt>{k}</dt><dd>{v}</dd></div>))}
          </dl>
        </div>
      ))}
      <p class="uses-foot">구체적인 모델이나 추천이 궁금하시면 <a href="/contact" class="u-line">편하게 물어봐 주세요</a>.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .uses-head { padding-top: clamp(2rem, 4vw, 3.2rem); padding-bottom: 1rem; }
  .uses-head .h1 { margin-top: 0.5rem; }
  .uses-head .lead { margin-top: 0.7rem; }
  .uses-body { padding-top: 1.5rem; }
  .uses-group { margin-top: 2.5rem; }
  .ug-title { font-size: var(--step-1); font-weight: 800; color: var(--ink-strong); margin-bottom: 1rem; letter-spacing: -0.02em; }
  .ug-list { display: flex; flex-direction: column; }
  .ug-list div { display: grid; grid-template-columns: 11rem 1fr; gap: 1.2rem; padding: 1rem 0; border-bottom: 1px dashed var(--dashed); }
  .ug-list dt { font-weight: 700; color: var(--brand); }
  .ug-list dd { color: var(--ink-soft); line-height: 1.6; }
  .uses-foot { margin-top: 2.5rem; color: var(--ink-mute); }
  .uses-foot a { color: var(--link); }
  @media (max-width: 560px) { .ug-list div { grid-template-columns: 1fr; gap: 0.3rem; } }
</style>
