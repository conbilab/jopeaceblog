---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Comments from '../../components/Comments.astro';
import { getCategory, GROWTH } from '../../lib/categories';
import { formatDate, readingTime, getRelatedPosts, getPublishedPosts, excerpt } from '../../lib/utils';
import { SITE } from '../../lib/site';

export async function getStaticPaths() {
  // 발행본만 페이지 생성 — draft:true 글이 URL로 노출되지 않도록 목록과 동일 정책 적용
  const posts = await getPublishedPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { data } = post;
const metaDesc = data.summary ?? excerpt((post.body ?? '').replace(/[#>*`_\[\]()!-]/g, ' '), 150);
const { Content, headings } = await render(post);
const cat = getCategory(data.category);
const growth = GROWTH[data.growth];
const mins = readingTime(post.body);
const related = await getRelatedPosts(post, 3);
const toc = headings.filter((h) => h.depth === 2);
const isLong = (post.body?.length ?? 0) > 900;

// 이전/다음 글
const all = await getPublishedPosts();
const idx = all.findIndex((p) => p.id === post.id);
const newer = idx > 0 ? all[idx - 1] : null;
const older = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : null;

const catStyle = `--cat: var(${cat.colorVar}); --cat-bg: var(${cat.bgVar});`;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  description: metaDesc,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
  image: new URL(data.cover ?? '/images/og-default.jpg', Astro.site ?? SITE.url).toString(),
  author: { '@type': 'Person', name: SITE.author, alternateName: SITE.authorHandle, url: SITE.url },
  publisher: { '@type': 'Organization', name: '피스웍스(Peaceworks)' },
  mainEntityOfPage: new URL(`/posts/${post.id}`, Astro.site ?? SITE.url).toString(),
  inLanguage: 'ko-KR',
  ...(data.tags.length ? { keywords: data.tags.join(', ') } : {}),
  articleSection: cat.label,
};

// 유형별 메타 박스
const foodMeta = data.category === 'food' && (data.place || data.rating);
const travelMeta = data.category === 'travel' && (data.region || data.companions);
const workMeta = data.category === 'work' && (data.client || data.role || data.result);
---

<BaseLayout title={data.title} description={metaDesc} image={data.cover ?? '/images/og-default.jpg'} type="article" publishedTime={data.pubDate} jsonLd={articleLd}>
  <article class="post" style={catStyle}>
    <!-- 헤더 -->
    <header class="post-head">
      <div class="wrap measure">
        <a href={`/category/${cat.key}`} class="post-kicker">
          <span class="cat-label">{cat.name}</span>
          <span class="pk-sep">·</span><span class="pk-label">{cat.label}</span>
        </a>
        <h1 class="post-title display">{data.title}</h1>
        {data.summary && <p class="post-summary lead">{data.summary}</p>}
        <div class="post-meta">
          <time class="num" datetime={data.pubDate.toISOString()}>{formatDate(data.pubDate)}</time>
          <span class="dot" aria-hidden="true">·</span>
          <span>읽는 데 약 {mins}분</span>
          {data.growth !== 'evergreen' && (<><span class="dot" aria-hidden="true">·</span><span>{growth.emoji} {growth.label}</span></>)}
        </div>
      </div>
    </header>

    {data.cover && (
      <div class="post-cover wrap wrap-wide reveal">
        <img src={data.cover} alt={data.coverAlt ?? ''} loading="eager" />
      </div>
    )}

    <div class="wrap post-body-wrap">
      <div class="post-grid">
        <!-- 목차 (긴 글) -->
        {toc.length >= 3 && (
          <aside class="post-toc" aria-label="목차">
            <p class="toc-h">목차</p>
            <nav>
              {toc.map((h) => (<a href={`#${h.slug}`}>{h.text}</a>))}
            </nav>
          </aside>
        )}

        <div class="post-main">
          <!-- 유형별 메타 카드 -->
          {foodMeta && (
            <dl class="meta-card card card--dashed">
              {data.place && (<div><dt>장소</dt><dd>{data.place}{data.location && ` · ${data.location}`}</dd></div>)}
              {data.rating !== undefined && (<div><dt>평점</dt><dd>{'★'.repeat(Math.round(data.rating))}<span class="mc-num num"> {data.rating}</span></dd></div>)}
              {data.priceRange && (<div><dt>가격대</dt><dd>{data.priceRange}</dd></div>)}
              {data.recommend && (<div><dt>추천</dt><dd>{data.recommend}</dd></div>)}
            </dl>
          )}
          {travelMeta && (
            <dl class="meta-card card card--dashed">
              {data.region && (<div><dt>지역</dt><dd>{data.region}</dd></div>)}
              {data.companions && (<div><dt>동행</dt><dd>{data.companions}</dd></div>)}
              {data.course && data.course.length > 0 && (<div><dt>코스</dt><dd>{data.course.join(' → ')}</dd></div>)}
            </dl>
          )}
          {workMeta && (
            <dl class="meta-card card card--dashed">
              {data.client && (<div><dt>클라이언트</dt><dd>{data.client}</dd></div>)}
              {data.role && (<div><dt>역할</dt><dd>{data.role}</dd></div>)}
              {data.result && (<div><dt>결과</dt><dd>{data.result}</dd></div>)}
            </dl>
          )}

          <div class:list={['prose', { 'prose--drop': isLong }]}>
            <Content />
          </div>

          {data.tags.length > 0 && (
            <div class="post-tags">
              {data.tags.map((t) => (<a href={`/tags/${encodeURIComponent(t)}`} class="tag">{t}</a>))}
            </div>
          )}

          <!-- 서명 -->
          <div class="post-sign card card--dashed">
            <img src="/images/logo-mark.jpg" alt="" class="ps-mark" width="44" height="44" />
            <div>
              <p class="ps-name">조피스 (조재빈)</p>
              <p class="ps-desc">콘텐츠로 평화를 만드는 사람 · 피스웍스 · 대전</p>
            </div>
            <a href="/about" class="btn btn-ghost ps-btn">소개 보기</a>
          </div>

          <!-- 이전/다음 -->
          <nav class="post-nav" aria-label="다른 글">
            {older ? (
              <a href={`/posts/${older.id}`} class="pn-item pn-prev">
                <span class="pn-label">← 이전 기록</span>
                <span class="pn-title">{older.data.title}</span>
              </a>
            ) : <span></span>}
            {newer && (
              <a href={`/posts/${newer.id}`} class="pn-item pn-next">
                <span class="pn-label">다음 기록 →</span>
                <span class="pn-title">{newer.data.title}</span>
              </a>
            )}
          </nav>

          <!-- 댓글/방명록 -->
          <section class="post-comments" aria-label="댓글">
            <h2 class="pc-h h3">이 글에 한마디</h2>
            <Comments term={post.id} />
          </section>
        </div>
      </div>
    </div>

    <!-- 연관 글 -->
    {related.length > 0 && (
      <section class="related section-sm">
        <div class="wrap">
          <h2 class="h3 display rel-h">이어서 읽어보세요</h2>
          <div class="rel-grid">
            {related.map((p, i) => (<PostCard post={p} variant="compact" index={i} />))}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .post-head { padding-top: clamp(2rem, 4vw, 3.5rem); padding-bottom: 1.6rem; }
  .post-kicker { display: inline-flex; align-items: center; gap: 0.4em; margin-bottom: 1rem; font-size: 0.85rem; }
  .pk-sep, .pk-label { color: var(--ink-mute); font-weight: 600; }
  .post-title { font-size: var(--step-4); font-weight: 440; margin-bottom: 0.8rem; }
  .post-summary { color: var(--ink-soft); margin-bottom: 1.2rem; }
  .post-meta { display: flex; flex-wrap: wrap; gap: 0.5em; align-items: center; font-size: 0.88rem; color: var(--ink-mute); }
  .post-meta .dot { opacity: 0.5; }

  .post-cover { margin-block: 1.5rem 2.5rem; }
  .post-cover img { width: 100%; max-height: 30rem; object-fit: cover; border-radius: var(--r-lg); border: 1px solid var(--line); box-shadow: var(--shadow-md); }

  .post-grid { display: grid; grid-template-columns: 1fr; justify-items: center; }
  .post-main { width: 100%; max-width: var(--measure); }

  /* 목차 (데스크톱 사이드) */
  .post-toc { display: none; }
  @media (min-width: 1100px) {
    .post-grid { grid-template-columns: 1fr minmax(0, var(--measure)) 1fr; align-items: start; }
    .post-main { grid-column: 2; }
    .post-toc { display: block; grid-column: 3; position: sticky; top: 6rem; padding-left: 2rem; align-self: start; max-width: 16rem; }
    .toc-h { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-mute); font-weight: 800; margin-bottom: 0.8rem; }
    .post-toc nav { display: flex; flex-direction: column; gap: 0.6rem; border-left: 2px solid var(--line); padding-left: 1rem; }
    .post-toc a { font-size: 0.85rem; color: var(--ink-mute); line-height: 1.4; transition: color var(--dur-fast); }
    .post-toc a:hover { color: var(--brand); }
  }

  .meta-card { display: grid; grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr)); gap: 1rem 1.5rem; padding: 1.3rem 1.5rem; margin-bottom: 2rem; background: var(--cat-bg); border-color: color-mix(in srgb, var(--cat) 28%, transparent); }
  .meta-card dt { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-mute); font-weight: 800; margin-bottom: 0.25rem; }
  .meta-card dd { font-size: 0.95rem; color: var(--ink-strong); font-weight: 600; }
  .meta-card .mc-num { color: var(--cat); }

  .post-tags { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px dashed var(--dashed); }

  .post-sign { display: flex; align-items: center; gap: 1rem; padding: 1.3rem 1.5rem; margin-top: 2.5rem; }
  .ps-mark { border-radius: 10px; background: #fff; flex: none; }
  .ps-name { font-weight: 800; color: var(--ink-strong); }
  .ps-desc { font-size: 0.85rem; color: var(--ink-mute); margin-top: 2px; }
  .ps-btn { margin-left: auto; font-size: 0.8rem; padding: 0.55em 1.1em; }

  .post-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2.5rem; }
  .pn-item { display: flex; flex-direction: column; gap: 0.3rem; padding: 1.1rem 1.3rem; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--card); transition: all var(--dur) var(--ease); }
  .pn-item:hover { border-color: var(--brand-mid); transform: translateY(-2px); }
  .pn-next { text-align: right; }
  .pn-label { font-size: 0.76rem; color: var(--ink-mute); font-weight: 700; }
  .pn-title { font-size: 0.92rem; font-weight: 700; color: var(--ink-strong); line-height: 1.4; }

  .post-comments { margin-top: 3.5rem; padding-top: 2rem; border-top: 1.5px dashed var(--dashed); }
  .pc-h { margin-bottom: 1.2rem; }

  .related { background: var(--bg-soft); border-top: 1px solid var(--line); margin-top: 3.5rem; }
  .rel-h { margin-bottom: 1.6rem; }
  .rel-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.3rem; }

  @media (max-width: 720px) {
    .post-nav { grid-template-columns: 1fr; }
    .pn-next { text-align: left; }
    .rel-grid { grid-template-columns: 1fr; }
    .post-sign { flex-wrap: wrap; }
    .ps-btn { margin-left: 0; }
  }
</style>
