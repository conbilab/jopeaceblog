---
import BaseLayout from '../layouts/BaseLayout.astro';
import letters from '../data/thanks.json';

const rot = [-1.6, 1.3, -0.8, 1.6, -1.2, 0.9, -1.9, 1.1];
---

<BaseLayout title="감사" description="수업·컨설팅에서 남겨주신 후기를 편지처럼 옮겨 담았습니다. 이름·상호·연락처는 모두 가렸습니다.">
  <section class="thanks">
    <div class="wrap">
      <span class="eyebrow">감사</span>
      <h1 class="pg-h">받은 마음을, <em>편지</em>처럼 붙여둡니다.</h1>
      <p class="lead">수업·컨설팅에서 남겨주신 후기를 편지 느낌으로 다시 담았습니다.</p>
      <div class="note">📮 실제로 받은 감사 후기 <b>{letters.length}통</b>을 편지로 옮겼어요. 카드를 누르면 크게 볼 수 있어요. <b>이름·상호·연락처는 모두 가렸습니다.</b></div>

      <div class="letters">
        {letters.map((l, i) => (
          <button
            class="letter"
            style={`--r:${rot[i % rot.length]}deg`}
            data-q={l.q}
            data-who={l.who}
            data-role={l.role}
          >
            <blockquote class="q">{l.q}</blockquote>
            <span class="sig">
              <span class="who">— {l.who}</span>
              <span class="role">{l.role}</span>
            </span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <div class="tlb" id="tlb" hidden>
    <div class="tlb-letter" role="dialog" aria-modal="true" aria-label="감사 편지">
      <button class="tlb-x" id="tlb-x" aria-label="닫기">✕</button>
      <blockquote class="q" id="tlb-q"></blockquote>
      <div class="sig">
        <span class="who" id="tlb-who"></span>
        <span class="role" id="tlb-role"></span>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const g = (id: string) => document.getElementById(id)!;
  const tlb = g('tlb');
  const open = (q: string, who: string, role: string) => {
    g('tlb-q').textContent = q;
    g('tlb-who').textContent = '— ' + who;
    g('tlb-role').textContent = role;
    tlb.hidden = false;
    document.body.style.overflow = 'hidden';
  };
  const close = () => { tlb.hidden = true; document.body.style.overflow = ''; };

  document.querySelectorAll<HTMLElement>('.letter').forEach((b) =>
    b.addEventListener('click', () => open(b.dataset.q || '', b.dataset.who || '', b.dataset.role || ''))
  );
  g('tlb-x').addEventListener('click', close);
  tlb.addEventListener('click', (e) => { if (e.target === tlb) close(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !tlb.hidden) close(); });
</script>

<style>
  .thanks { padding-top: clamp(2rem, 4vw, 3rem); padding-bottom: 3rem; }
  .eyebrow { font-family: var(--font-ui); font-size: 0.76rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-primary); }
  .pg-h { font-size: var(--step-3); font-weight: 800; letter-spacing: -0.03em; color: var(--ink-strong); margin-top: 0.6rem; }
  .pg-h em { font-style: normal; color: var(--color-primary); }
  .lead { margin-top: 0.7rem; color: var(--ink-soft); font-size: 1.05rem; }
  .note { margin-top: 1.2rem; padding: 0.9rem 1.2rem; background: var(--color-primary-soft); border: 1px solid color-mix(in srgb, var(--color-primary) 25%, transparent); border-radius: var(--r-md); font-size: 0.9rem; color: var(--color-primary-deep); line-height: 1.6; }
  .note b { font-weight: 800; }

  /* 작은 편지 카드 */
  .letters { margin-top: 2rem; display: grid; grid-template-columns: repeat(auto-fill, minmax(215px, 1fr)); gap: 1.3rem; }
  .letter { position: relative; text-align: left; background: linear-gradient(#fffdf7, #f7f0e0); border: 1px solid #e7dcc4; border-radius: 6px; padding: 1.25rem 1.15rem 1rem; box-shadow: 0 8px 20px rgba(80, 60, 30, 0.12), 0 2px 0 #efe6d2; transform: rotate(var(--r)); cursor: pointer; transition: transform var(--dur) var(--ease), box-shadow var(--dur); }
  .letter:hover { transform: rotate(0deg) translateY(-3px); box-shadow: 0 16px 34px rgba(80, 60, 30, 0.2); }
  .letter::before { content: ''; position: absolute; top: -8px; left: 18px; width: 52px; height: 15px; background: rgba(209, 85, 42, 0.16); border: 1px dashed rgba(209, 85, 42, 0.4); transform: rotate(-4deg); border-radius: 2px; }
  .letter .q { font-size: 0.86rem; line-height: 1.6; color: #46402f; word-break: keep-all; margin: 0; display: -webkit-box; -webkit-line-clamp: 5; -webkit-box-orient: vertical; overflow: hidden; }
  .letter .sig { margin-top: 0.85rem; padding-top: 0.7rem; border-top: 1px dashed #dfd3ba; display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; }
  .letter .who { font-size: 0.78rem; font-weight: 700; color: var(--color-primary-deep); }
  .letter .role { font-size: 0.7rem; color: var(--ink-mute); white-space: nowrap; }

  /* 클릭 시 확대 모달 */
  .tlb { position: fixed; inset: 0; z-index: var(--z-top); display: grid; place-items: center; padding: 1.5rem; background: rgba(30, 22, 12, 0.5); backdrop-filter: blur(7px); -webkit-backdrop-filter: blur(7px); animation: tlb-in 0.25s var(--ease); }
  .tlb[hidden] { display: none; }
  @keyframes tlb-in { from { opacity: 0; } to { opacity: 1; } }
  .tlb-letter { position: relative; width: min(560px, 100%); background: linear-gradient(#fffdf7, #f6efdd); border: 1px solid #e3d7bd; border-radius: 10px; padding: clamp(1.8rem, 5vw, 2.8rem); box-shadow: 0 30px 80px rgba(40, 28, 12, 0.4); animation: tlb-pop 0.35s var(--ease-out); }
  @keyframes tlb-pop { from { transform: scale(0.9) translateY(10px); opacity: 0; } to { transform: none; opacity: 1; } }
  .tlb-letter::before { content: ''; position: absolute; top: -12px; left: 32px; width: 90px; height: 24px; background: rgba(209, 85, 42, 0.16); border: 1px dashed rgba(209, 85, 42, 0.45); transform: rotate(-3deg); border-radius: 2px; }
  .tlb-letter .q { font-size: clamp(1.05rem, 2.2vw, 1.25rem); line-height: 1.85; color: #3a3226; word-break: keep-all; margin: 0; }
  .tlb-letter .sig { margin-top: 1.4rem; padding-top: 1rem; border-top: 1px dashed #dcd0b6; display: flex; align-items: baseline; justify-content: space-between; gap: 0.6rem; }
  .tlb-letter .who { font-size: 0.98rem; font-weight: 800; color: var(--color-primary-deep); }
  .tlb-letter .role { font-size: 0.85rem; color: var(--ink-mute); }
  .tlb-x { position: absolute; top: 0.7rem; right: 0.9rem; width: 2rem; height: 2rem; border-radius: 50%; color: var(--ink-mute); font-size: 1rem; }
  .tlb-x:hover { background: rgba(0, 0, 0, 0.06); color: var(--ink-strong); }

  :root[data-theme='dark'] .letter { background: linear-gradient(#26221a, #201d16); border-color: #3a352c; }
  :root[data-theme='dark'] .letter .q { color: #cdc4b0; }
  :root[data-theme='dark'] .tlb-letter { background: linear-gradient(#28241b, #211d16); border-color: #3a352c; }
  :root[data-theme='dark'] .tlb-letter .q { color: #ded5c1; }

  @media (max-width: 560px) { .letters { grid-template-columns: 1fr 1fr; gap: 0.9rem; } }
</style>
