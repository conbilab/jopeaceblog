---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('timeline')).sort(
  (a, b) => a.data.year - b.data.year || a.data.order - b.data.order
);

const TYPE: Record<string, { label: string; color: string }> = {
  work: { label: '작업', color: 'var(--cat-work)' },
  award: { label: '수상', color: 'var(--cat-win)' },
  press: { label: '언론', color: 'var(--terra)' },
  lecture: { label: '강의', color: 'var(--cat-daily)' },
  founding: { label: '설립', color: 'var(--brand)' },
  life: { label: '기록', color: 'var(--gold)' },
};
---

<BaseLayout title="이력 · 연대기" description="조재빈(조피스)이 걸어온 길 — 영상 제작부터 피스웍스, 그리고 이 기록까지.">
  <header class="tl-head">
    <div class="wrap">
      <span class="kicker kicker--caps">The timeline</span>
      <h1 class="h1 display">걸어온 길</h1>
      <p class="lead">화려한 이력서가 아니라, 무엇을 어떻게 해왔는지의 기록입니다. 잘된 것도 헤맨 것도 모두 제 시간이에요.</p>
    </div>
  </header>

  <section class="tl-body">
    <div class="wrap measure">
      <ol class="timeline" role="list">
        {entries.map((e, i) => {
          const ty = TYPE[e.data.type] ?? TYPE.work;
          return (
            <li class="tl-item reveal" data-delay={String((i % 4) + 1)} style={`--ty:${ty.color}`}>
              <div class="tl-node" aria-hidden="true"></div>
              <div class="tl-year num">{e.data.date ?? e.data.year}</div>
              <div class="tl-card card">
                <span class="tl-type" style={`color:${ty.color}; background:color-mix(in srgb, ${ty.color} 12%, transparent)`}>{ty.label}</span>
                <h2 class="tl-title">{e.data.title}</h2>
                {e.data.description && <p class="tl-desc">{e.data.description}</p>}
                {e.data.link && <a href={e.data.link} class="btn-text tl-link">자세히</a>}
              </div>
            </li>
          );
        })}
      </ol>
      <p class="tl-foot">…그리고 오늘도, 한 줄을 더합니다. 🕊️</p>
    </div>
  </section>
</BaseLayout>

<style>
  .tl-head { padding-top: clamp(2rem, 4vw, 3.2rem); padding-bottom: 1.5rem; }
  .tl-head .h1 { margin-top: 0.5rem; }
  .tl-head .lead { margin-top: 0.7rem; max-width: 46ch; }
  .tl-body { padding-top: 2.5rem; }
  .timeline { position: relative; list-style: none; padding-left: 0; }
  .timeline::before { content: ''; position: absolute; left: 6.7rem; top: 0.5rem; bottom: 2rem; width: 2px; background: linear-gradient(var(--line-strong), var(--line)); }
  .tl-item { position: relative; display: grid; grid-template-columns: 5.5rem 1fr; gap: 1.6rem; padding-bottom: 1.6rem; }
  .tl-year { font-size: 0.95rem; font-weight: 600; color: var(--ink-mute); text-align: right; padding-top: 1.1rem; }
  .tl-node { position: absolute; left: 6.25rem; top: 1.3rem; width: 0.95rem; height: 0.95rem; border-radius: 50%; background: var(--bg); border: 3px solid var(--ty); z-index: 1; transition: transform var(--dur) var(--ease); }
  .tl-item:hover .tl-node { transform: scale(1.3); }
  .tl-card { padding: 1.2rem 1.4rem; position: relative; }
  .tl-card::before { content: ''; position: absolute; left: -0.55rem; top: 1.35rem; width: 0; height: 0; border: 7px solid transparent; border-right-color: var(--card); }
  .tl-type { font-size: 0.72rem; font-weight: 800; padding: 0.3em 0.7em; border-radius: var(--r-pill); letter-spacing: 0.02em; }
  .tl-title { font-size: var(--step-1); font-weight: 800; color: var(--ink-strong); margin-top: 0.7rem; letter-spacing: -0.02em; line-height: 1.4; }
  .tl-desc { margin-top: 0.5rem; color: var(--ink-soft); line-height: 1.6; font-size: 0.94rem; }
  .tl-link { margin-top: 0.7rem; }
  .tl-foot { margin-top: 1.5rem; padding-left: 7.1rem; color: var(--ink-mute); font-style: italic; font-family: var(--font-serif); }

  @media (max-width: 600px) {
    .timeline::before { left: 0.45rem; }
    .tl-item { grid-template-columns: 1fr; gap: 0.5rem; padding-left: 1.8rem; }
    .tl-year { text-align: left; padding-top: 0; color: var(--gold-ink); font-weight: 700; }
    .tl-node { left: 0; top: 0.4rem; }
    .tl-card::before { display: none; }
    .tl-foot { padding-left: 1.8rem; }
  }
</style>
