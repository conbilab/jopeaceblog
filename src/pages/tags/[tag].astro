---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts, getAllTags } from '../../lib/utils';

export async function getStaticPaths() {
  const tags = await getAllTags();
  const posts = await getPublishedPosts();
  return tags.map(({ tag }) => ({
    params: { tag },
    props: { tag, posts: posts.filter((p) => p.data.tags.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`'${tag}' 태그가 달린 조피스의 기록.`}>
  <header class="tagp-head">
    <div class="wrap">
      <a href="/tags" class="back-link">← 모든 태그</a>
      <h1 class="h1 display tagp-title"><span class="tp-hash">#</span>{tag}</h1>
      <p class="lead num">{posts.length}개의 기록</p>
    </div>
  </header>
  <section class="tagp-body">
    <div class="wrap">
      <div class="tagp-grid">
        {posts.map((post, i) => (<PostCard post={post} variant="default" index={i} />))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tagp-head { padding-top: clamp(2rem, 4vw, 3rem); padding-bottom: 1.5rem; border-bottom: 1px solid var(--line); }
  .back-link { font-size: 0.85rem; color: var(--ink-mute); font-weight: 600; }
  .back-link:hover { color: var(--brand); }
  .tagp-title { margin-top: 1rem; }
  .tp-hash { color: var(--gold); }
  .tagp-head .lead { margin-top: 0.4rem; color: var(--ink-mute); }
  .tagp-body { padding-top: 2.2rem; }
  .tagp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }
  @media (max-width: 900px) { .tagp-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .tagp-grid { grid-template-columns: 1fr; } }
</style>
