---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTags } from '../../lib/utils';

const tags = await getAllTags();
const max = Math.max(1, ...tags.map((t) => t.count));
function size(c: number) {
  return 0.9 + (c / max) * 1.1; // 0.9 ~ 2.0rem
}
---

<BaseLayout title="태그" description="조피스의 기록을 주제별로 — 태그 모음.">
  <header class="tags-head">
    <div class="wrap measure">
      <span class="kicker kicker--caps">Tags</span>
      <h1 class="h1 display">태그로 찾아보기</h1>
      <p class="lead">관심 있는 주제로 모아서 보세요. 글자가 클수록 더 자주 적은 이야기예요.</p>
    </div>
  </header>
  <section class="tags-body">
    <div class="wrap measure">
      {tags.length > 0 ? (
        <div class="tag-cloud">
          {tags.map((t) => (
            <a href={`/tags/${encodeURIComponent(t.tag)}`} class="tc-tag" style={`font-size:${size(t.count)}rem`}>
              <span class="tc-hash">#</span>{t.tag}<span class="tc-count num">{t.count}</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="card card--dashed empty-note">아직 태그가 없어요. 🌱</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .tags-head { padding-top: clamp(2rem, 4vw, 3.2rem); padding-bottom: 1rem; }
  .tags-head .h1 { margin-top: 0.5rem; }
  .tags-head .lead { margin-top: 0.7rem; }
  .tags-body { padding-top: 1.5rem; }
  .tag-cloud { display: flex; flex-wrap: wrap; gap: 0.7rem 1.1rem; align-items: baseline; }
  .tc-tag { font-weight: 700; color: var(--ink-soft); line-height: 1.4; transition: color var(--dur-fast); }
  .tc-tag:hover { color: var(--gold-ink); }
  .tc-hash { color: var(--gold); opacity: 0.7; }
  .tc-count { font-size: 0.6em; color: var(--ink-faint); margin-left: 0.15em; vertical-align: super; }
  .empty-note { padding: 3rem; text-align: center; color: var(--ink-mute); }
</style>
