---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts, groupByYear, formatDateShort } from '../lib/utils';
import { getCategory } from '../lib/categories';

const posts = await getPublishedPosts();
const years = groupByYear(posts);
---

<BaseLayout title="아카이브" description="조피스의 모든 기록을 연도별로 — 시간순 전체 보기.">
  <header class="ar-head">
    <div class="wrap measure">
      <span class="kicker kicker--caps">Archive</span>
      <h1 class="h1 display">전체 기록, 연도별로</h1>
      <p class="lead num">{posts.length}개의 기록 · {years.length}개의 해</p>
    </div>
  </header>

  <section class="ar-body">
    <div class="wrap measure">
      {years.map((y) => (
        <div class="ar-year">
          <h2 class="ar-y num">{y.year}</h2>
          <ul class="ar-list" role="list">
            {y.posts.map((p) => {
              const cat = getCategory(p.data.category);
              return (
                <li class="ar-item" style={`--cat: var(${cat.colorVar})`}>
                  <a href={`/posts/${p.id}`}>
                    <span class="ar-date num">{formatDateShort(p.data.pubDate)}</span>
                    <span class="ar-cat" aria-hidden="true">{cat.emoji}</span>
                    <span class="ar-title">{p.data.title}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .ar-head { padding-top: clamp(2rem, 4vw, 3.2rem); padding-bottom: 1rem; }
  .ar-head .h1 { margin-top: 0.5rem; }
  .ar-head .lead { margin-top: 0.5rem; color: var(--ink-mute); }
  .ar-body { padding-top: 2rem; }
  .ar-year { margin-top: 2.5rem; }
  .ar-y { font-family: var(--font-serif); font-size: var(--step-3); font-weight: 400; color: var(--ink-faint); margin-bottom: 0.8rem; }
  .ar-list { display: flex; flex-direction: column; }
  .ar-item a { display: grid; grid-template-columns: 4rem 1.5rem 1fr; align-items: baseline; gap: 0.8rem; padding: 0.85rem 0.4rem; border-bottom: 1px dashed var(--dashed); transition: padding var(--dur) var(--ease), background var(--dur); }
  .ar-item a:hover { padding-left: 0.9rem; background: linear-gradient(90deg, color-mix(in srgb, var(--cat) 8%, transparent), transparent 60%); }
  .ar-date { font-size: 0.8rem; color: var(--ink-mute); white-space: nowrap; }
  .ar-cat { font-size: 0.9rem; }
  .ar-title { font-weight: 600; color: var(--ink-strong); letter-spacing: -0.02em; }
  .ar-item a:hover .ar-title { color: var(--cat); }
  @media (max-width: 480px) { .ar-item a { grid-template-columns: 3.2rem 1.2rem 1fr; gap: 0.5rem; } }
</style>
