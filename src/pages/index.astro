---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecordCard from '../components/RecordCard.astro';
import FeaturedCard from '../components/FeaturedCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../lib/site';
import { TYPE_ORDER, TYPES } from '../lib/taxonomy';
import { getPublishedRecords, getProjects, getStandards, getRecordsByType, getFeaturedRecords } from '../lib/utils';

const records = await getPublishedRecords();
const big = (await getFeaturedRecords(1))[0] ?? records[0];
const smallFeatured = records.filter((r) => r.id !== big?.id).slice(0, 4);
const projects = (await getProjects()).slice(0, 6);
const standards = (await getStandards()).slice(0, 4);
const goodThings = (await getRecordsByType('food-place')).slice(0, 3);
const learning = (await getRecordsByType('learning')).slice(0, 3);
const chips = TYPE_ORDER.map((k) => TYPES[k]);
---

<BaseLayout>
  <!-- 1) HERO -->
  <section class="hero">
    <div class="hero-deco" aria-hidden="true">
      <span class="orb orb-1"></span><span class="orb orb-2"></span>
      <span class="dot d1"></span><span class="dot d2"></span><span class="dot d3"></span>
    </div>
    <div class="wrap hero-inner">
      <span class="hero-kicker">{SITE.titleEn} · 개인 기록장</span>
      <h1 class="hero-name">{SITE.title}</h1>
      <p class="hero-sub">{SITE.subtitle}</p>
      <p class="hero-slogan"><span class="hs-mark">“</span>{SITE.slogan}<span class="hs-line" aria-hidden="true"></span></p>
      <p class="hero-body">
        이곳은 나를 포장하는 공간이 아니라, 사람으로 살아가며 보고 느끼고 행동한 것을 남기는 기록장입니다.
        마케팅, AI, 콘텐츠, 사업 운영, 배움, 맛과 장소, 그리고 지키고 싶은 기준들을 이곳에 기록합니다.
      </p>
      <div class="hero-cta">
        <a href="/records" class="btn btn-primary">최근 기록 보기</a>
        <a href="/standards" class="btn btn-ghost">나의 기준 보기</a>
        <a href="/now" class="btn btn-text">지금 하는 일 →</a>
      </div>
    </div>
  </section>

  <!-- 2) FEATURED -->
  {big && (
    <section class="section-sm">
      <div class="wrap">
        <div class="sec-head"><h2 class="sec-title">대표 기록</h2><a href="/records" class="sec-more">전체 기록 →</a></div>
        <div class="featured">
          <FeaturedCard record={big} />
          <div class="feat-small">
            {smallFeatured.map((r, i) => (<RecordCard record={r} index={i} compact />))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- 3) RECORD TYPES -->
  <section class="section-sm">
    <div class="wrap">
      <p class="chips-label">내가 자주 기록하는 것</p>
      <div class="chips">
        {chips.map((c) => (
          <a href={`/records?type=${c.key}`} class="chip-link" style={`--bg: var(${c.bg}); --ink: var(${c.ink});`}><span class="ce">{c.emoji}</span>{c.label}</a>
        ))}
        <a href="/standards" class="chip-link chip-link--std"><span class="ce">🕊️</span>지키고 싶은 것</a>
      </div>
    </div>
  </section>

  <!-- 4) STANDARDS -->
  <section class="section standards-sec">
    <div class="wrap">
      <div class="sec-head"><h2 class="sec-title">나의 기준</h2><a href="/standards" class="sec-more">전부 보기 →</a></div>
      <p class="sec-lead">완벽하다는 뜻이 아니라, 계속 이 방향으로 돌아오기 위한 기준입니다.</p>
      <div class="std-grid">
        {standards.map((s, i) => (
          <a href={`/standards#${s.id}`} class="std-card reveal" data-delay={String((i % 4) + 1)}>
            <span class="std-n">{String(s.data.order).padStart(2, '0')}</span>
            <span class="std-t">{s.data.title}</span>
            <span class="std-s">{s.data.summary}</span>
            <span class="std-go" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 5) WORK -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head"><h2 class="sec-title">일과 프로젝트</h2><a href="/work" class="sec-more">전부 보기 →</a></div>
      <div class="proj-grid">{projects.map((p, i) => (<ProjectCard project={p} index={i} />))}</div>
    </div>
  </section>

  <!-- 6) GOOD THINGS -->
  {goodThings.length > 0 && (
    <section class="section good-sec">
      <div class="wrap">
        <div class="sec-head"><h2 class="sec-title">좋았던 것들</h2><a href="/good-things" class="sec-more">더 보기 →</a></div>
        <p class="sec-lead">전문가의 추천이 아니라, 제가 무엇을 좋다고 느끼는 사람인지 보여주는 기록입니다.</p>
        <div class="rec-grid">{goodThings.map((r, i) => (<RecordCard record={r} index={i} />))}</div>
      </div>
    </section>
  )}

  <!-- 7) LEARNING -->
  {learning.length > 0 && (
    <section class="section">
      <div class="wrap">
        <div class="sec-head"><h2 class="sec-title">배운 것들</h2><a href="/learning" class="sec-more">더 보기 →</a></div>
        <div class="rec-grid">{learning.map((r, i) => (<RecordCard record={r} index={i} />))}</div>
      </div>
    </section>
  )}

  <!-- 8) CTA -->
  <section class="section cta-sec">
    <div class="wrap">
      <div class="cta-box">
        <p class="cta-text">함께 일하거나 이야기 나누고 싶은 일이 있다면 연락 주세요.<br />마케팅, 콘텐츠, AI 활용, 홈페이지 제작, 강의와 관련된 일을 함께할 수 있습니다.</p>
        <a href="/contact" class="btn btn-ghost">연락하기</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero { position: relative; overflow: hidden; padding-block: clamp(3rem, 7vw, 6.5rem) clamp(2.5rem, 5vw, 4rem); }
  .hero-deco { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .orb { position: absolute; border-radius: 50%; filter: blur(60px); }
  .orb-1 { width: 30rem; height: 30rem; top: -10rem; right: -6rem; background: radial-gradient(circle, color-mix(in srgb, var(--color-primary) 22%, transparent), transparent 70%); }
  .orb-2 { width: 22rem; height: 22rem; bottom: -8rem; left: -6rem; background: radial-gradient(circle, color-mix(in srgb, var(--color-warm) 18%, transparent), transparent 70%); }
  .dot { position: absolute; width: 7px; height: 7px; border-radius: 50%; }
  .d1 { background: var(--color-primary); top: 18%; right: 22%; opacity: 0.5; }
  .d2 { background: var(--color-warm); top: 38%; right: 12%; opacity: 0.55; }
  .d3 { background: var(--color-green); bottom: 22%; left: 16%; opacity: 0.4; }
  .hero-inner { position: relative; z-index: 1; max-width: 44rem; }
  .hero-kicker { font-size: 0.78rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-primary); }
  .hero-name { font-size: var(--step-5); font-weight: 800; letter-spacing: -0.05em; line-height: 1.02; color: var(--ink-strong); margin-top: 0.8rem; }
  .hero-sub { margin-top: 1.2rem; font-size: clamp(1.15rem, 2.2vw, 1.5rem); font-weight: 700; color: var(--ink-strong); line-height: 1.5; letter-spacing: -0.02em; max-width: 30ch; }
  .hero-slogan { position: relative; display: inline-block; margin-top: 0.9rem; font-family: var(--font-serif); font-style: italic; font-size: clamp(1.3rem, 2.4vw, 1.7rem); color: var(--color-primary-ink); }
  .hs-mark { color: var(--color-warm); }
  .hs-line { display: block; height: 7px; margin-top: 2px; border-radius: 4px; background: color-mix(in srgb, var(--color-primary) 25%, transparent); }
  .hero-body { margin-top: 1.5rem; font-size: 1.05rem; line-height: 1.85; color: var(--ink-soft); max-width: 42ch; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 0.8rem; align-items: center; margin-top: 2rem; }

  /* section heads */
  .sec-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 1.5rem; }
  .sec-title { font-size: var(--step-2); font-weight: 800; letter-spacing: -0.035em; color: var(--ink-strong); }
  .sec-more { font-size: 0.9rem; font-weight: 700; color: var(--color-primary); white-space: nowrap; }
  .sec-more:hover { color: var(--color-primary-deep); }
  .sec-lead { margin-top: -0.6rem; margin-bottom: 1.5rem; color: var(--ink-mute); font-size: 0.98rem; }

  /* featured */
  .featured { display: flex; flex-direction: column; gap: 1.2rem; }
  .feat-small { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.1rem; }

  .rec-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
  .proj-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }

  /* chips */
  .chips-label { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-mute); font-weight: 800; margin-bottom: 1rem; }
  .chips { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .chip-link { display: inline-flex; align-items: center; gap: 0.4em; font-size: 0.9rem; font-weight: 700; padding: 0.6em 1em; border-radius: var(--r-pill); background: var(--bg, var(--color-primary-soft)); color: var(--ink, var(--color-primary)); transition: transform var(--dur-fast) var(--ease); }
  .chip-link:hover { transform: translateY(-2px); }
  .chip-link--std { background: var(--color-primary-soft); color: var(--color-primary-deep); }

  /* standards grid (cards) */
  .standards-sec { background: var(--bg-soft); border-block: 1px solid var(--line); }
  .std-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.1rem; }
  .std-card { position: relative; display: flex; flex-direction: column; gap: 0.4rem; padding: 1.4rem 1.4rem 1.5rem; background: var(--color-card); border: 1px solid var(--line); border-radius: var(--r-card); transition: transform var(--dur) var(--ease), border-color var(--dur); overflow: hidden; }
  .std-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--color-primary); opacity: 0.8; }
  .std-card:hover { transform: translateY(-3px); border-color: color-mix(in srgb, var(--color-primary) 40%, transparent); }
  .std-n { font-family: var(--font-serif); font-size: 1.5rem; color: var(--color-primary); font-weight: 500; line-height: 1; }
  .std-t { font-size: 1.05rem; font-weight: 800; color: var(--ink-strong); letter-spacing: -0.02em; }
  .std-s { font-size: 0.88rem; color: var(--ink-mute); line-height: 1.55; }
  .std-go { position: absolute; right: 1.2rem; bottom: 1.2rem; color: var(--color-primary); opacity: 0; transform: translateX(-4px); transition: all var(--dur) var(--ease); }
  .std-card:hover .std-go { opacity: 1; transform: none; }

  .good-sec { background: var(--bg-soft); border-block: 1px solid var(--line); }

  /* CTA */
  .cta-box { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; padding: 2rem 2.2rem; border: 1px solid var(--line); border-radius: var(--r-lg); background: var(--color-card); flex-wrap: wrap; box-shadow: var(--shadow-sm); }
  .cta-text { color: var(--ink-soft); line-height: 1.7; }

  @media (max-width: 980px) {
    .feat-small { grid-template-columns: 1fr 1fr; }
    .std-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 880px) {
    .rec-grid, .proj-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .rec-grid, .proj-grid, .feat-small, .std-grid { grid-template-columns: 1fr; }
  }
</style>
